@page
@model AtsManager.Pages.Cargas.IndexModel
@using System.Globalization

<script src="https://cdn.tailwindcss.com"></script>
<style>
    .message-box {
        padding: 1rem;
        border-radius: 0.5rem;
        margin-bottom: 1.5rem;
        font-weight: 600;
        box-shadow: 0 4px 6px -1px rgba(0, 0, 0, 0.1), 0 2px 4px -2px rgba(0, 0, 0, 0.06);
    }
    .success { background-color: #d1fae5; color: #065f46; border-left: 5px solid #10b981; }
    .error { background-color: #fee2e2; color: #991b1b; border-left: 5px solid #ef4444; }
    .warning { background-color: #fef3c7; color: #92400e; border-left: 5px solid #f59e0b; }
</style>

<div class="min-h-screen p-4 sm:p-8">
    <div class="max-w-2xl mx-auto bg-white p-6 sm:p-10 rounded-xl shadow-2xl">
        
        <h1 class="text-3xl font-extrabold text-gray-900 mb-2 border-b pb-2">
            Carga de Compras desde SRI
        </h1>
        <p class="text-gray-500 mb-6">
            Cargue el archivo TXT/CSV generado por el reporte del SRI para compras y notas de crédito.
        </p>

        @* Mensaje de proceso *@
        @if (!string.IsNullOrEmpty(Model.MensajeCarga))
        {
            var msgClass = Model.MensajeCarga.Contains("❌") ? "error" : (Model.MensajeCarga.Contains("⚠️") ? "warning" : "success");
            <div class="message-box @msgClass">
                @Model.MensajeCarga
            </div>
        }

        @* Historial de Cargas *@
        @if (Model.CargasLotes.Any())
        {
            <div class="mb-6 bg-white rounded-lg shadow p-4 border border-gray-200">
                <h3 class="text-lg font-bold text-gray-800 mb-3 flex items-center">
                    <i class="fas fa-history mr-2 text-indigo-500"></i>Historial de Cargas
                </h3>
                <div class="overflow-x-auto">
                    <table class="min-w-full divide-y divide-gray-200 text-sm">
                        <thead class="bg-gray-50">
                            <tr>
                                <th class="px-3 py-2 text-left text-xs font-medium text-gray-500 uppercase">Período</th>
                                <th class="px-3 py-2 text-left text-xs font-medium text-gray-500 uppercase">Tipo</th>
                                <th class="px-3 py-2 text-left text-xs font-medium text-gray-500 uppercase">Registros</th>
                                <th class="px-3 py-2 text-left text-xs font-medium text-gray-500 uppercase">Fecha Carga</th>
                                <th class="px-3 py-2 text-right text-xs font-medium text-gray-500 uppercase">Acciones</th>
                            </tr>
                        </thead>
                        <tbody class="bg-white divide-y divide-gray-200">
                            @foreach (var lote in Model.CargasLotes)
                            {
                                <tr class="hover:bg-gray-50">
                                    <td class="px-3 py-2 whitespace-nowrap text-gray-900">@lote.Anio/@lote.Mes.ToString("00")</td>
                                    <td class="px-3 py-2 whitespace-nowrap text-gray-500">@lote.TipoArchivo</td>
                                    <td class="px-3 py-2 whitespace-nowrap text-gray-500">@lote.TotalRegistros</td>
                                    <td class="px-3 py-2 whitespace-nowrap text-gray-500">@lote.FechaCarga.ToString("dd/MM/yyyy HH:mm")</td>
                                    <td class="px-3 py-2 whitespace-nowrap text-right">
                                        <form method="post" asp-page-handler="DeleteLote" asp-route-id="@lote.Id" style="display:inline;" onsubmit="return confirm('¿Eliminar esta carga?');">
                                            <button type="submit" class="text-red-600 hover:text-red-800 font-medium text-xs">
                                                <i class="fas fa-trash mr-1"></i>Eliminar
                                            </button>
                                        </form>
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            </div>
        }

        <form method="post" enctype="multipart/form-data" class="space-y-6">
            
            <input type="hidden" asp-for="ConfirmarReemplazo" />

            <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
                <div>
                    <label for="Anio" class="block text-sm font-medium text-gray-700 mb-1">Año Fiscal</label>
                    <select asp-for="Anio" id="Anio" class="w-full rounded-lg border-gray-300 shadow-sm focus:ring-indigo-500 focus:border-indigo-500">
                        @{
                            var currentYear = DateTime.Now.Year;
                            for (int i = currentYear - 5; i <= currentYear + 1; i++)
                            {
                                <option value="@i" selected="@(i == Model.Anio)">@i</option>
                            }
                        }
                    </select>
                </div>

                <div>
                    <label for="Mes" class="block text-sm font-medium text-gray-700 mb-1">Mes Fiscal</label>
                    <select asp-for="Mes" id="Mes" class="w-full rounded-lg border-gray-300 shadow-sm focus:ring-indigo-500 focus:border-indigo-500">
                        @for (int i = 1; i <= 12; i++)
                        {
                            <option value="@i" selected="@(i == Model.Mes)">@i.ToString("00") - @CultureInfo.CurrentCulture.DateTimeFormat.GetMonthName(i)</option>
                        }
                    </select>
                </div>
            </div>

            <div>
                <label for="TipoArchivo" class="block text-sm font-medium text-gray-700 mb-1">Tipo de Documento</label>
                <select asp-for="TipoArchivo" id="TipoArchivo" class="w-full rounded-lg border-gray-300 shadow-sm focus:ring-indigo-500 focus:border-indigo-500">
                    <option value="">Seleccione...</option>
                    <option value="Compras">Facturas de Compra</option>
                    <option value="NCCompras">Notas de Crédito de Compra</option>
                </select>
            </div>

            <div>
                <label for="ArchivoCarga" class="block text-sm font-medium text-gray-700 mb-2">
                    Archivo TXT/CSV del SRI
                </label>
                <div class="mt-1 flex justify-center px-6 pt-5 pb-6 border-2 border-gray-300 border-dashed rounded-lg hover:border-indigo-400 transition-colors">
                    <div class="space-y-1 text-center">
                        <svg class="mx-auto h-12 w-12 text-gray-400" stroke="currentColor" fill="none" viewBox="0 0 48 48">
                            <path d="M28 8H12a4 4 0 00-4 4v20m32-12v8m0 0v8a4 4 0 01-4 4H12a4 4 0 01-4-4v-4m32-4l-3-11a2 2 0 00-2-1H17a2 2 0 00-2 1l-3 11m12-4h.02" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
                        </svg>
                        <div class="flex text-sm text-gray-600 justify-center">
                            <label for="ArchivoCarga" class="relative cursor-pointer bg-white rounded-md font-medium text-indigo-600 hover:text-indigo-500 focus-within:outline-none">
                                <span>Seleccionar archivo</span>
                                <input type="file" id="ArchivoCarga" name="ArchivoCarga" accept=".txt,.csv" class="sr-only">
                            </label>
                        </div>
                        <p class="text-xs text-gray-500 mt-2">
                            Archivo TXT o CSV generado por el reporte de Compras del SRI
                        </p>
                    </div>
                </div>
            </div>

            <div class="pt-4">
                <button type="submit" id="submit-btn" class="w-full inline-flex justify-center py-3 px-4 border border-transparent shadow-sm text-sm font-medium rounded-lg text-white bg-indigo-600 hover:bg-indigo-700 focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-indigo-500 transition-colors">
                    <i class="fas fa-upload mr-2 mt-0.5"></i>
                    Procesar Archivo
                </button>
            </div>
        </form>
    </div>
</div>

@section Scripts {
    <script>
        document.querySelector('form').addEventListener('submit', function() {
            const tipo = document.getElementById('TipoArchivo')?.value;
            const archivo = document.getElementById('ArchivoCarga')?.files?.length;
            
            if (!tipo) {
                alert('Seleccione el tipo de documento');
                return false;
            }
            if (!archivo) {
                alert('Seleccione el archivo');
                return false;
            }
            
            document.getElementById('submit-btn').disabled = true;
            document.getElementById('submit-btn').innerHTML = '<i class="fas fa-spinner fa-spin mr-2"></i>Procesando...';
            return true;
        });
    </script>
}
