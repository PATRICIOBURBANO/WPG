@page
@model AtsManager.Pages.Cargas.IndexModel
@using System.Globalization

<script src="https://cdn.tailwindcss.com"></script>
<style>
    /* Estilos de Tailwind para mensajes de error/éxito */
    .message-box {
        padding: 1rem;
        border-radius: 0.5rem;
        margin-bottom: 1.5rem;
        font-weight: 600;
        box-shadow: 0 4px 6px -1px rgba(0, 0, 0, 0.1), 0 2px 4px -2px rgba(0, 0, 0, 0.06);
    }

    .success {
        background-color: #d1fae5;
        color: #065f46;
        border-left: 5px solid #10b981;
    }

    .error {
        background-color: #fee2e2;
        color: #991b1b;
        border-left: 5px solid #ef4444;
    }
</style>

<div class="min-h-screen p-4 sm:p-8">
    <div class="max-w-4xl mx-auto bg-white p-6 sm:p-10 rounded-xl shadow-2xl">

        <h1 class="text-3xl font-extrabold text-gray-900 mb-6 border-b pb-2">
            Carga Masiva de Anexos Transaccionales (ATS)
        </h1>
        <p class="text-gray-500 mb-8">
            Seleccione el período fiscal y el tipo de anexo para cargar archivos CSV o TXT.
        </p>

        @* Mostrar mensaje de proceso (éxito o error) *@
        @if (!string.IsNullOrEmpty(Model.MensajeCarga))
        {
            <div class="message-box @(Model.MensajeCarga.Contains("❌") ? "error" : "success")">
                @Model.MensajeCarga
            </div>
        }

        @* Mostrar errores de validación si existen *@
        @if (Model.ErroresValidacion != null && Model.ErroresValidacion.Any())
        {
            <div class="message-box error">
                <h4 class="font-bold mb-2">Se encontraron @Model.ErroresValidacion.Count errores en el archivo:</h4>
                <ul class="list-disc list-inside text-sm mt-2 max-h-48 overflow-y-auto">
                    @foreach (var error in Model.ErroresValidacion)
                    {
                        <li>@error</li>
                    }
                </ul>
            </div>
        }

        @* -------------------------------------------------------- *@
        @* FORMULARIO DE CARGA *@
        @* -------------------------------------------------------- *@
        <form method="post" enctype="multipart/form-data" class="space-y-6">

            @* 🟢 Campo oculto para la confirmación de reemplazo *@
            <input type="hidden" asp-for="ConfirmarReemplazo" value="@(Model.ConfirmarReemplazo ? "true" : "false")" />

            <div class="grid grid-cols-1 md:grid-cols-3 gap-6">

                <div>
                    <label for="Anio" class="block text-sm font-medium text-gray-700">Año Fiscal</label>
                    <select asp-for="Anio" id="Anio" class="mt-1 block w-full pl-3 pr-10 py-2 text-base border-gray-300 focus:outline-none focus:ring-indigo-500 focus:border-indigo-500 sm:text-sm rounded-md shadow-sm transition duration-150 ease-in-out">
                        @{
                            var currentYear = DateTime.Now.Year;
                            for (int i = currentYear - 5; i <= currentYear + 1; i++)
                            {
                                <option value="@i" selected="@(i == Model.Anio)">@i</option>
                            }
                        }
                    </select>
                </div>

                <div>
                    <label for="Mes" class="block text-sm font-medium text-gray-700">Mes Fiscal</label>
                    <select asp-for="Mes" id="Mes" class="mt-1 block w-full pl-3 pr-10 py-2 text-base border-gray-300 focus:outline-none focus:ring-indigo-500 focus:border-indigo-500 sm:text-sm rounded-md shadow-sm transition duration-150 ease-in-out">
                        @for (int i = 1; i <= 12; i++)
                        {
                            <option value="@i" selected="@(i == Model.Mes)">@i.ToString("00") - @CultureInfo.CurrentCulture.DateTimeFormat.GetMonthName(i)</option>
                        }
                    </select>
                </div>

                <div>
                    <label for="EmpresaId" class="block text-sm font-medium text-gray-700">Empresa</label>
                    <select asp-for="EmpresaId" id="EmpresaId" class="mt-1 block w-full pl-3 pr-10 py-2 text-base border-gray-300 focus:outline-none focus:ring-indigo-500 focus:border-indigo-500 sm:text-sm rounded-md shadow-sm transition duration-150 ease-in-out">
                        <option value="0">Seleccione...</option>
                        @foreach (var empresa in Model.Empresas)
                        {
                            <option value="@empresa.Id">@empresa.Ruc - @empresa.RazonSocial</option>
                        }
                    </select>
                </div>
            </div>

            <div class="grid grid-cols-1 md:grid-cols-3 gap-6 mt-4">
                <div>
                    <label for="TipoArchivo" class="block text-sm font-medium text-gray-700">Tipo de Anexo</label>
                    @* Este select define el tipo base (COMPRAS). El C# lo ajustará a NCCOMPRAS si es necesario. *@
                    <select asp-for="TipoArchivo" id="TipoArchivo" class="mt-1 block w-full pl-3 pr-10 py-2 text-base border-gray-300 focus:outline-none focus:ring-indigo-500 focus:border-indigo-500 sm:text-sm rounded-md shadow-sm transition duration-150 ease-in-out">
                        <option value="">Seleccione...</option>
                        <option value="Compras">COMPRAS</option>
                        <option value="NCCompras">NOTAS DE CREDITO COMPRAS</option>
                        <option value="Ventas">VENTAS</option>
                        <option value="Retenciones">RETENCIONES</option>
                    </select>
                </div>
                <div>
                    <label asp-for="ContextoCarga" class="block text-sm font-medium text-gray-700">Origen XML</label>
                    <select asp-for="ContextoCarga" class="mt-1 block w-full pl-3 pr-10 py-2 text-base border-gray-300 focus:outline-none focus:ring-indigo-500 focus:border-indigo-500 sm:text-sm rounded-md shadow-sm transition duration-150 ease-in-out">
                        <option value="RECIBIDOS">Recibidos</option>
                        <option value="EMITIDOS">Emitidos</option>
                    </select>
                </div>
            </div>

            
            <div class="py-4">
                <label for="ArchivoCarga" class="block text-sm font-medium text-gray-700 mb-2">
                    Subir archivo TXT/CSV (alternativa)
                </label>

                <div class="mt-1 flex items-center justify-center px-6 pt-5 pb-6 border-2 border-gray-300 border-dashed rounded-md transition duration-150 ease-in-out hover:border-indigo-400">
                    <div class="space-y-1 text-center">
                        <div class="flex text-sm text-gray-600 justify-center">
                            <label for="ArchivoCarga"
                                   class="relative cursor-pointer bg-white rounded-md font-medium text-indigo-600 hover:text-indigo-500
                              focus-within:outline-none focus-within:ring-2 focus-within:ring-offset-2 focus-within:ring-indigo-500">
                                <span>Seleccionar archivo</span>
                                <input type="file"
                                       id="ArchivoCarga"
                                       name="ArchivoCarga"
                                       accept=".txt,.csv"
                                       class="sr-only" />
                            </label>
                        </div>
                        <p class="text-xs text-gray-500 mt-2">
                            Puede cargar <strong>TXT/CSV</strong> del SRI (Recibidos o Emitidos).<br />
                            Si selecciona un archivo aquí, <strong>no es necesario</strong> seleccionar la carpeta de XML.
                        </p>
                    </div>
                </div>
            </div>

<div class="py-4">
                <label for="XmlFiles" class="block text-sm font-medium text-gray-700 mb-2">
                    Seleccionar carpeta con XML
                </label>

                <div class="mt-1 flex justify-center px-6 pt-5 pb-6 border-2 border-gray-300 border-dashed rounded-md transition duration-150 ease-in-out hover:border-indigo-400">
                    <div class="space-y-1 text-center">

                        <svg class="mx-auto h-12 w-12 text-gray-400" stroke="currentColor" fill="none"
                             viewBox="0 0 48 48" aria-hidden="true">
                            <path d="M28 8H12a4 4 0 00-4 4v20m32-12v8m0 0v8a4 4 0 01-4 4H12a4 4 0 01-4-4v-4m32-4l-3-11a2 2 0 00-2-1H17a2 2 0 00-2 1l-3 11m12-4h.02"
                                  stroke-width="2" stroke-linecap="round" stroke-linejoin="round" />
                        </svg>

                        <div class="flex text-sm text-gray-600 justify-center">
                            <label for="XmlFiles"
                                   class="relative cursor-pointer bg-white rounded-md font-medium text-indigo-600 hover:text-indigo-500
                              focus-within:outline-none focus-within:ring-2 focus-within:ring-offset-2 focus-within:ring-indigo-500">
                                <span>Seleccionar carpeta</span>

                                <input type="file"
                                       id="XmlFiles"
                                       name="XmlFiles"
                                       multiple
                                       webkitdirectory
                                       directory
                                       accept=".xml"
                                       class="sr-only" />
                            </label>
                        </div>

                        <p class="text-xs text-gray-500 mt-2">
                            Se importarán todos los archivos <strong>.xml</strong> de la carpeta seleccionada
                        </p>
                    </div>
                </div>
            </div>


            <div class="pt-5">
                <button type="submit" id="submit-btn" class="w-full inline-flex justify-center py-3 px-4 border border-transparent shadow-sm text-sm font-medium rounded-md text-white bg-indigo-600 hover:bg-indigo-700 focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-indigo-500 transition duration-150 ease-in-out transform hover:scale-105">
                    <svg class="animate-spin -ml-1 mr-3 h-5 w-5 text-white hidden" id="loading-spinner" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24">
                        <circle class="opacity-25" cx="12" cy="12" r="10" stroke="currentColor" stroke-width="4"></circle>
                        <path class="opacity-75" fill="currentColor" d="M4 12a8 8 0 018-8V0C5.373 0 0 5.373 0 12h4zm2 5.291A7.962 7.962 0 014 12H0c0 3.042 1.135 5.824 3 7.938l3-2.647z"></path>
                    </svg>
                    Procesar y Validar Carga
                </button>
            </div>
        </form>
        @* FORMULARIO FIN *@


    </div>

    @* --- SECCIÓN DE HISTORIAL DE CARGAS --- *@
    <div class="max-w-4xl mx-auto bg-white p-6 sm:p-10 rounded-xl shadow-2xl mt-10">
        <h2 class="text-2xl font-bold text-gray-900 mb-6 border-b pb-2">
            Historial de Cargas por Lote
        </h2>

        @if (Model.CargasLotes == null || !Model.CargasLotes.Any())
        {
            <p class="text-gray-500">No se han encontrado cargas por lote anteriores.</p>
        }
        else
        {
            <div class="shadow overflow-hidden border-b border-gray-200 sm:rounded-lg">
                <table class="min-w-full divide-y divide-gray-200">
                    <thead class="bg-gray-50">
                        <tr>
                            <th scope="col" class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Período</th>
                            <th scope="col" class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Tipo Anexo</th>
                            <th scope="col" class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Registros</th>
                            <th scope="col" class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Fecha Carga</th>
                            <th scope="col" class="relative px-6 py-3">Acciones</th>
                        </tr>
                    </thead>
                    <tbody class="bg-white divide-y divide-gray-200">
                        @foreach (var lote in Model.CargasLotes)
                        {
                            <tr>
                                <td class="px-6 py-4 whitespace-nowrap text-sm text-gray-900">@lote.Anio/@lote.Mes.ToString("00")</td>
                                <td class="px-6 py-4 whitespace-nowrap text-sm text-gray-500">@lote.TipoArchivo</td>
                                <td class="px-6 py-4 whitespace-nowrap text-sm text-gray-500">@lote.TotalRegistros</td>
                                <td class="px-6 py-4 whitespace-nowrap text-sm text-gray-500">@lote.FechaCarga.ToString("dd/MM/yyyy HH:mm")</td>
                                <td class="px-6 py-4 whitespace-nowrap text-right text-sm font-medium">
                                    @* Formulario para la acción de eliminación (DeleteLote) *@
                                    <form method="post" asp-page-handler="DeleteLote" asp-route-id="@lote.Id" style="display:inline;" onsubmit="return confirm('ADVERTENCIA: ¿Está seguro de eliminar esta carga? Esto eliminará los @lote.TipoArchivo correspondientes y no se puede deshacer.');">
                                        <button type="submit" class="text-red-600 hover:text-red-900">Eliminar Lote</button>
                                    </form>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        }

    </div>
</div>


@section Scripts {
    <script>
        document.addEventListener('DOMContentLoaded', () => {
            // Confirmación de reemplazo (si aplica)
            const confirmar = '@(Model.ConfirmarReemplazo ? "true" : "false")' === 'true';
            const mensaje = '@Html.Raw((Model.MensajeCarga ?? "").Replace("'", "\'"))';

            if (confirmar && mensaje) {
                const ok = confirm(mensaje.replace("⚠️", "").replace("**", ""));
                if (ok) {
                    const input = document.getElementById('ConfirmarReemplazo');
                    if (input) input.value = 'true';
                    document.querySelector('form')?.submit();
                } else {
                    const input = document.getElementById('ConfirmarReemplazo');
                    if (input) input.value = 'false';
                }
            }

            const form = document.querySelector('form');
            const submitButton = document.getElementById('submit-btn');
            const spinner = document.getElementById('loading-spinner');

            form?.addEventListener('submit', () => {
                // Si es confirmación, no tocamos UI
                if (document.getElementById('ConfirmarReemplazo')?.value === 'true') return true;

                const tipo = document.getElementById('TipoArchivo')?.value || "";
                const tieneTxt = (document.getElementById('ArchivoCarga')?.files?.length || 0) > 0;
                const tieneXml = (document.getElementById('XmlFiles')?.files?.length || 0) > 0;

                // Dejamos que el servidor muestre mensajes si falta algo
                if (!tipo || (!tieneTxt && !tieneXml)) return true;

                submitButton.disabled = true;
                submitButton.classList.add('bg-indigo-400', 'cursor-not-allowed');
                spinner.classList.remove('hidden');
            });
        });
    </script>
}
