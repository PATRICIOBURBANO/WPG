@page
@model AtsManager.Pages.ImportarXML.IndexModel
@using System.Globalization

<script src="https://cdn.tailwindcss.com"></script>
<style>
    .message-box {
        padding: 1rem;
        border-radius: 0.5rem;
        margin-bottom: 1.5rem;
        font-weight: 600;
    }

    .success {
        background-color: #d1fae5;
        color: #065f46;
        border-left: 5px solid #10b981;
    }

    .warning {
        background-color: #fffbeb;
        color: #92400e;
        border-left: 5px solid #f59e0b;
    }

    .error {
        background-color: #fee2e2;
        color: #991b1b;
        border-left: 5px solid #ef4444;
    }
</style>

<div class="max-w-4xl mx-auto bg-white p-8 rounded-xl shadow-lg">
    <h1 class="text-3xl font-extrabold text-gray-900 mb-6 border-b pb-2">
        Carga de Documentos Electrónicos por Lotes
    </h1>

    <form method="post" asp-page-handler="Importar" class="mb-8 border-2 border-dashed border-indigo-300 p-6 rounded-lg bg-indigo-50">
        <h2 class="text-lg font-semibold text-indigo-800 mb-4">Especificar Carpeta de Origen</h2>
        <p class="text-sm text-indigo-700 mb-4">
            El sistema buscará y procesará todos los archivos XML (`*.xml`) directamente dentro de esta ruta.
        </p>
        <div class="flex space-x-4 items-end">
            <div class="flex-grow">
                <label asp-for="RutaCarpeta" class="block text-sm font-medium text-gray-700">Ruta Absoluta de la Carpeta</label>
                <input asp-for="RutaCarpeta" class="mt-1 block w-full rounded-md border-gray-300 shadow-sm p-2" placeholder="Ej: C:\SRI_XMLs\Recibidos" />
                <span asp-validation-for="RutaCarpeta" class="text-red-600 text-xs"></span>
            </div>
            <button type="submit" class="h-10 px-4 py-2 text-sm font-medium rounded-md text-white bg-green-600 hover:bg-green-700 shadow-sm transition">
                <i class="fas fa-upload mr-2"></i> Procesar e Importar Lotes
            </button>
        </div>
    </form>

    @if (Model.MensajesResultado.Any())
    {
        <h2 class="text-xl font-bold text-gray-800 mb-4">Resultado del Procesamiento</h2>
        <div class="space-y-3">
            @foreach (var mensaje in Model.MensajesResultado)
            {
                // ✨ CORRECCIÓN APLICADA: Se eliminó el @{ y } innecesario
                var clase = "success";
                if (mensaje.StartsWith("ERROR", StringComparison.OrdinalIgnoreCase))
                {
                    clase = "error";
                }
                else if (mensaje.StartsWith("ADVERTENCIA", StringComparison.OrdinalIgnoreCase) || mensaje.StartsWith("Archivos XML encontrados"))
                {
                    clase = "warning";
                }

                <div class="message-box @clase">
                    @mensaje
                </div>
            }
        </div>
    }
</div>