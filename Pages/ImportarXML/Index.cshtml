@page
@model AtsManager.Pages.ImportarXML.IndexModel
@using System.Globalization

<script src="https://cdn.tailwindcss.com"></script>

<style>
    .message-box {
        padding: 1rem;
        border-radius: 0.5rem;
        margin-bottom: 1rem;
        font-weight: 600;
    }

    .success {
        background-color: #d1fae5;
        color: #065f46;
        border-left: 5px solid #10b981;
    }

    .warning {
        background-color: #fffbeb;
        color: #92400e;
        border-left: 5px solid #f59e0b;
    }

    .error {
        background-color: #fee2e2;
        color: #991b1b;
        border-left: 5px solid #ef4444;
    }
</style>
<div class="max-w-4xl mx-auto bg-white p-8 rounded-xl shadow-lg">
    <h1 class="text-3xl font-extrabold text-gray-900 mb-6 border-b pb-2">
        Carga de Documentos Electrónicos XML
    </h1>

    <!-- ================= FORM ================= -->
    <form method="post" enctype="multipart/form-data" class="space-y-6">

        <!-- Año / Mes / Tipo -->
        <div class="grid grid-cols-1 md:grid-cols-4 gap-6">
            <div>
                <label asp-for="Anio" class="block text-sm font-medium text-gray-700">Año Fiscal</label>
                <select asp-for="Anio" class="mt-1 block w-full rounded-md border-gray-300 shadow-sm p-2">
                    @{
                        var currentYear = DateTime.Now.Year;
                        for (int i = currentYear - 5; i <= currentYear + 1; i++)
                        {
                            <option value="@i">@i</option>
                        }
                    }
                </select>
            </div>

            <div>
                <label asp-for="Mes" class="block text-sm font-medium text-gray-700">Mes Fiscal</label>
                <select asp-for="Mes" class="mt-1 block w-full rounded-md border-gray-300 shadow-sm p-2">
                    @for (int i = 1; i <= 12; i++)
                    {
                        <option value="@i">
                            @i.ToString("00") - @CultureInfo.CurrentCulture.DateTimeFormat.GetMonthName(i)
                        </option>
                    }
                </select>
            </div>

            <div>
                <label asp-for="TipoArchivo" class="block text-sm font-medium text-gray-700">Tipo de Anexo</label>
                <select asp-for="TipoArchivo" class="mt-1 block w-full rounded-md border-gray-300 shadow-sm p-2">
                    <option value="XML">XML Electrónicos</option>
                </select>
            </div>
        
            <div>
                <label asp-for="ContextoCarga" class="block text-sm font-medium text-gray-700">Origen de la carpeta</label>
                <select asp-for="ContextoCarga" class="mt-1 block w-full rounded-md border-gray-300 shadow-sm p-2">
                    <option value="RECIBIDOS">Recibidos</option>
                    <option value="EMITIDOS">Emitidos</option>
                </select>
                <p class="text-xs text-gray-500 mt-1">Recibidos: compras excepto retenciones. Emitidos: ventas excepto retenciones.</p>
            </div>
</div>

        <!-- ================= SELECTOR DE CARPETA ================= -->
        <div>
            <label class="block text-sm font-medium text-gray-700 mb-2">
                Seleccionar carpeta con XML
            </label>

            <div class="flex justify-center px-6 pt-5 pb-6 border-2 border-dashed border-indigo-300 rounded-md bg-indigo-50">
                <div class="text-center space-y-2">
                    <div class="text-sm text-indigo-700 font-medium">
                        Seleccione una carpeta que contenga archivos XML
                    </div>

                    <!-- IMPORTANTE: NO asp-for -->
                    <input type="file"
                           name="XmlFiles"
                           id="XmlFiles"
                           multiple
                           webkitdirectory
                           directory
                           accept=".xml"
                           class="block mx-auto text-sm text-gray-600" />

                    <p class="text-xs text-gray-500">
                        Se procesarán todos los archivos <strong>.xml</strong> de la carpeta seleccionada
                    </p>
                </div>
            </div>
        </div>

        <!-- ================= BOTÓN ================= -->
        <div>
            <button type="submit"
                    class="w-full py-3 px-4 rounded-md text-white font-semibold bg-indigo-600 hover:bg-indigo-700 transition">
                Procesar e Importar XML
            </button>
        </div>
    </form>

    <!-- ================= MENSAJE GENERAL ================= -->
    @if (!string.IsNullOrWhiteSpace(Model.MensajeCarga))
    {
        <div class="message-box mt-6 @(Model.MensajeCarga.StartsWith("❌") ? "error" : "success")">
            @Model.MensajeCarga
        </div>
    }

    <!-- ================= RESULTADOS ================= -->
    @if (Model.ResultadosImportacion.Any())
    {
        <h2 class="text-xl font-bold text-gray-800 mt-8 mb-4">
            Resultado del Procesamiento
        </h2>

        <div class="space-y-3">
            @foreach (var mensaje in Model.ResultadosImportacion)
            {
                var clase = "success";

                if (mensaje.StartsWith("❌"))
                {
                    clase = "error";
                }
                else if (mensaje.StartsWith("ADVERTENCIA") || mensaje.StartsWith("Archivos XML"))
                {
                    clase = "warning";
                }

                <div class="message-box @clase">
                    @mensaje
                </div>
            }
        </div>
    }
</div>
