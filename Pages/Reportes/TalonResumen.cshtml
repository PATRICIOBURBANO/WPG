@page
@model AtsManager.Pages.Reportes.TalonResumenModel
@using System.Globalization

<script src="https://cdn.tailwindcss.com"></script>

<div class="w-full px-2 py-4">
    <h1 class="text-2xl font-extrabold text-gray-900 mb-4">Talón Resumen ATS</h1>

    <form method="get" class="mb-6 bg-white p-4 rounded-lg shadow space-y-4">
        <div class="grid grid-cols-1 md:grid-cols-4 gap-4">
            <div>
                <label class="block text-xs font-medium text-gray-700">Empresa</label>
                <select asp-for="RucEmpresa" class="w-full rounded border-gray-300 text-sm" onchange="this.form.submit()">
                    <option value="">Seleccione empresa...</option>
                    @foreach (var emp in Model.Empresas)
                    {
                        <option value="@emp.Ruc" selected="@(emp.Ruc == Model.RucEmpresa)">@emp.Ruc - @emp.RazonSocial</option>
                    }
                </select>
            </div>
            <div>
                <label class="block text-xs font-medium text-gray-700">Año</label>
                <select asp-for="Anio" class="w-full rounded border-gray-300 text-sm" onchange="this.form.submit()">
                    @for (int y = DateTime.Now.Year; y >= DateTime.Now.Year - 5; y--)
                    {
                        <option value="@y" selected="@(y == Model.Anio)">@y</option>
                    }
                </select>
            </div>
            <div>
                <label class="block text-xs font-medium text-gray-700">Mes</label>
                <select asp-for="Mes" class="w-full rounded border-gray-300 text-sm" onchange="this.form.submit()">
                    <option value="0">Todos</option>
                    @for (int m = 1; m <= 12; m++)
                    {
                        <option value="@m" selected="@(m == Model.Mes)">@m.ToString("00") - @CultureInfo.CurrentCulture.DateTimeFormat.GetMonthName(m)</option>
                    }
                </select>
            </div>
            <div class="flex items-end">
                <button type="submit" class="w-full bg-indigo-600 text-white px-4 py-2 rounded text-sm hover:bg-indigo-700">Actualizar</button>
            </div>
        </div>
    </form>

    @if (!string.IsNullOrWhiteSpace(Model.RucEmpresa) && Model.TieneDatos)
    {
        <div class="bg-white rounded-lg shadow overflow-hidden mb-6">
            <div class="bg-gray-50 px-4 py-3 border-b">
                <h2 class="text-lg font-bold text-gray-800">COMPRAS</h2>
            </div>
            <table class="min-w-full divide-y divide-gray-200">
                <thead class="bg-gray-50">
                    <tr>
                        <th class="px-4 py-2 text-left text-xs font-medium text-gray-500 uppercase">Código</th>
                        <th class="px-4 py-2 text-left text-xs font-medium text-gray-500 uppercase">Transacción</th>
                        <th class="px-4 py-2 text-right text-xs font-medium text-gray-500 uppercase">N° Registros</th>
                        <th class="px-4 py-2 text-right text-xs font-medium text-gray-500 uppercase">BI Tarifa 0%</th>
                        <th class="px-4 py-2 text-right text-xs font-medium text-gray-500 uppercase">BI Tarifa Diferente 0%</th>
                        <th class="px-4 py-2 text-right text-xs font-medium text-gray-500 uppercase">BI No Objeto IVA</th>
                        <th class="px-4 py-2 text-right text-xs font-medium text-gray-500 uppercase">Valor IVA</th>
                    </tr>
                </thead>
                <tbody class="divide-y divide-gray-200">
                    @foreach (var item in Model.ComprasResumen)
                    {
                        <tr class="@(item.EsNegativo ? "bg-red-50" : "")">
                            <td class="px-4 py-2 text-sm">@item.Codigo</td>
                            <td class="px-4 py-2 text-sm">@item.Transaccion</td>
                            <td class="px-4 py-2 text-right text-sm">@item.NumRegistros</td>
                            <td class="px-4 py-2 text-right text-sm">@item.Base0.ToString("N2")</td>
                            <td class="px-4 py-2 text-right text-sm">@item.BaseGrav.ToString("N2")</td>
                            <td class="px-4 py-2 text-right text-sm">@item.BaseNoGraIva.ToString("N2")</td>
                            <td class="px-4 py-2 text-right text-sm">@item.MontoIva.ToString("N2")</td>
                        </tr>
                    }
                </tbody>
                <tfoot class="bg-gray-100 font-bold">
                    <tr>
                        <td colspan="3" class="px-4 py-2 text-right text-sm">TOTAL</td>
                        <td class="px-4 py-2 text-right text-sm">@Model.TotalComprasBase0.ToString("N2")</td>
                        <td class="px-4 py-2 text-right text-sm">@Model.TotalComprasBaseGrav.ToString("N2")</td>
                        <td class="px-4 py-2 text-right text-sm">@Model.TotalComprasBaseNoGraIva.ToString("N2")</td>
                        <td class="px-4 py-2 text-right text-sm">@Model.TotalComprasIva.ToString("N2")</td>
                    </tr>
                </tfoot>
            </table>
        </div>

        <div class="bg-white rounded-lg shadow overflow-hidden mb-6">
            <div class="bg-gray-50 px-4 py-3 border-b">
                <h2 class="text-lg font-bold text-gray-800">VENTAS</h2>
            </div>
            <table class="min-w-full divide-y divide-gray-200">
                <thead class="bg-gray-50">
                    <tr>
                        <th class="px-4 py-2 text-left text-xs font-medium text-gray-500 uppercase">Código</th>
                        <th class="px-4 py-2 text-left text-xs font-medium text-gray-500 uppercase">Transacción</th>
                        <th class="px-4 py-2 text-right text-xs font-medium text-gray-500 uppercase">N° Registros</th>
                        <th class="px-4 py-2 text-right text-xs font-medium text-gray-500 uppercase">BI Tarifa 0%</th>
                        <th class="px-4 py-2 text-right text-xs font-medium text-gray-500 uppercase">BI Tarifa Diferente 0%</th>
                        <th class="px-4 py-2 text-right text-xs font-medium text-gray-500 uppercase">BI No Objeto IVA</th>
                        <th class="px-4 py-2 text-right text-xs font-medium text-gray-500 uppercase">Valor IVA</th>
                    </tr>
                </thead>
                <tbody class="divide-y divide-gray-200">
                    @foreach (var item in Model.VentasResumen)
                    {
                        <tr class="@(item.EsNegativo ? "bg-red-50" : "")">
                            <td class="px-4 py-2 text-sm">@item.Codigo</td>
                            <td class="px-4 py-2 text-sm">@item.Transaccion</td>
                            <td class="px-4 py-2 text-right text-sm">@item.NumRegistros</td>
                            <td class="px-4 py-2 text-right text-sm">@item.Base0.ToString("N2")</td>
                            <td class="px-4 py-2 text-right text-sm">@item.BaseGrav.ToString("N2")</td>
                            <td class="px-4 py-2 text-right text-sm">@item.BaseNoGraIva.ToString("N2")</td>
                            <td class="px-4 py-2 text-right text-sm">@item.MontoIva.ToString("N2")</td>
                        </tr>
                    }
                </tbody>
                <tfoot class="bg-gray-100 font-bold">
                    <tr>
                        <td colspan="3" class="px-4 py-2 text-right text-sm">TOTAL</td>
                        <td class="px-4 py-2 text-right text-sm">@Model.TotalVentasBase0.ToString("N2")</td>
                        <td class="px-4 py-2 text-right text-sm">@Model.TotalVentasBaseGrav.ToString("N2")</td>
                        <td class="px-4 py-2 text-right text-sm">@Model.TotalVentasBaseNoGraIva.ToString("N2")</td>
                        <td class="px-4 py-2 text-right text-sm">@Model.TotalVentasIva.ToString("N2")</td>
                    </tr>
                </tfoot>
            </table>
        </div>

        <div class="bg-white rounded-lg shadow overflow-hidden">
            <div class="bg-gray-50 px-4 py-3 border-b">
                <h2 class="text-lg font-bold text-gray-800">RESUMEN DE RETENCIONES - AGENTE DE RETENCIÓN</h2>
            </div>
            <div class="grid grid-cols-1 md:grid-cols-2 gap-0">
                <div class="border-r">
                    <h3 class="text-sm font-bold text-gray-700 px-4 py-2 bg-gray-50 border-b">RETENCIÓN EN LA FUENTE DE IVA</h3>
                    <table class="min-w-full">
                        <tbody class="divide-y divide-gray-200">
                            <tr class="bg-blue-50 font-semibold">
                                <td class="px-4 py-2 text-sm">Retenciones IVA Recibidas (ValRetIva)</td>
                                <td class="px-4 py-2 text-right text-sm">@Model.TotalRetIvaRecibida.ToString("N2")</td>
                            </tr>
                            <tr>
                                <td class="px-4 py-2 text-sm">Retención IVA 10%</td>
                                <td class="px-4 py-2 text-right text-sm">@Model.TotalRetIva10.ToString("N2")</td>
                            </tr>
                            <tr>
                                <td class="px-4 py-2 text-sm">Retención IVA 20%</td>
                                <td class="px-4 py-2 text-right text-sm">@Model.TotalRetIva20.ToString("N2")</td>
                            </tr>
                            <tr>
                                <td class="px-4 py-2 text-sm">Retención IVA 30%</td>
                                <td class="px-4 py-2 text-right text-sm">@Model.TotalRetIva30.ToString("N2")</td>
                            </tr>
                            <tr>
                                <td class="px-4 py-2 text-sm">Retención IVA 50%</td>
                                <td class="px-4 py-2 text-right text-sm">@Model.TotalRetIva50.ToString("N2")</td>
                            </tr>
                            <tr>
                                <td class="px-4 py-2 text-sm">Retención IVA 70%</td>
                                <td class="px-4 py-2 text-right text-sm">@Model.TotalRetIva70.ToString("N2")</td>
                            </tr>
                            <tr>
                                <td class="px-4 py-2 text-sm">Retención IVA 100%</td>
                                <td class="px-4 py-2 text-right text-sm">@Model.TotalRetIva100.ToString("N2")</td>
                            </tr>
                            <tr class="bg-gray-100 font-bold">
                                <td class="px-4 py-2 text-sm">TOTAL RETENCIONES IVA</td>
                                <td class="px-4 py-2 text-right text-sm">@Model.TotalRetIva.ToString("N2")</td>
                            </tr>
                        </tbody>
                    </table>
                </div>
                <div>
                    <h3 class="text-sm font-bold text-gray-700 px-4 py-2 bg-gray-50 border-b">RETENCIÓN EN LA FUENTE DE RENTA</h3>
                    <table class="min-w-full">
                        <tbody class="divide-y divide-gray-200">
                            <tr>
                                <td class="px-4 py-2 text-sm">Retenciones Recibidas</td>
                                <td class="px-4 py-2 text-right text-sm">@Model.TotalRetRentaRecibida.ToString("N2")</td>
                            </tr>
                            <tr>
                                <td class="px-4 py-2 text-sm">Retenciones Emitidas</td>
                                <td class="px-4 py-2 text-right text-sm">@Model.TotalRetRentaEmitida.ToString("N2")</td>
                            </tr>
                            <tr class="bg-gray-100 font-bold">
                                <td class="px-4 py-2 text-sm">TOTAL RETENCIONES RENTA</td>
                                <td class="px-4 py-2 text-right text-sm">@Model.TotalRetRenta.ToString("N2")</td>
                            </tr>
                        </tbody>
                    </table>
                </div>
            </div>
        </div>

        <form method="post" asp-page-handler="ExportarExcel" class="mt-4">
            <input type="hidden" asp-for="RucEmpresa" />
            <input type="hidden" asp-for="Anio" />
            <input type="hidden" asp-for="Mes" />
            <button type="submit" class="bg-green-600 text-white px-4 py-2 rounded text-sm hover:bg-green-700">
                <i class="fas fa-file-excel mr-2"></i>Exportar Excel
            </button>
        </form>
    }
    else if (!string.IsNullOrWhiteSpace(Model.RucEmpresa))
    {
        <div class="bg-yellow-50 p-4 rounded-lg text-yellow-800">No se encontraron registros para los filtros seleccionados.</div>
    }
    else
    {
        <div class="bg-blue-50 p-4 rounded-lg text-blue-800">Seleccione una empresa para ver el Talón Resumen.</div>
    }
</div>
