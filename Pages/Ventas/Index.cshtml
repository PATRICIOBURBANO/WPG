@page
@model AtsManager.Pages.Ventas.IndexModel
@using System.Globalization

<div class="max-w-7xl mx-auto">
    <div class="flex justify-between items-center mb-6">
        <h1 class="text-3xl font-extrabold text-gray-900">Listado de Ventas</h1>
        <a asp-page="Create" class="inline-flex items-center px-4 py-2 border border-transparent shadow-sm text-sm font-medium rounded-md text-white bg-indigo-600 hover:bg-indigo-700">
            <svg class="h-5 w-5 mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 6v6m0 0v6m0-6h6m-6 0H6"></path></svg>
            Nueva Venta Manual
        </a>
    </div>

    @* Mostrar mensaje de éxito/error (usando TempData) *@
    @if (!string.IsNullOrEmpty(Model.MensajeProceso))
    {
        <div class="p-4 rounded-lg border-l-4 mb-6 font-semibold @(Model.MensajeProceso.StartsWith("ERROR") ? "bg-red-100 text-red-800 border-red-500" : "bg-green-100 text-green-800 border-green-500")">
            @Model.MensajeProceso
        </div>
    }

    <div class="shadow overflow-hidden border-b border-gray-200 sm:rounded-lg">
        <table class="min-w-full divide-y divide-gray-200">
            <thead class="bg-gray-50">
                <tr>
                    <th scope="col" class="px-2 py-2 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Periodo</th>
                    <th scope="col" class="px-2 py-2 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Fecha</th>
                    <th scope="col" class="px-2 py-2 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Tipo</th>
                    <th scope="col" class="px-2 py-2 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Comprobante</th>
                    <th scope="col" class="px-2 py-2 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Cliente</th>
                    <th scope="col" class="px-2 py-2 text-right text-xs font-medium text-gray-500 uppercase tracking-wider">Base 0%</th>
                    <th scope="col" class="px-2 py-2 text-right text-xs font-medium text-gray-500 uppercase tracking-wider">Base 12%/15%</th>
                    <th scope="col" class="px-2 py-2 text-right text-xs font-medium text-gray-500 uppercase tracking-wider">IVA</th>
                    <th scope="col" class="px-2 py-2 text-right text-xs font-medium text-gray-500 uppercase tracking-wider">Total</th>
                    <th scope="col" class="relative px-2 py-2">
                        <span class="sr-only">Acciones</span>
                    </th>
                </tr>
            </thead>
            <tbody class="bg-white divide-y divide-gray-200">
                @foreach (var item in Model.Venta)
                {
                    <tr>
                        <td class="px-2 py-2 whitespace-nowrap text-xs text-gray-900">
                            @item.Anio/@item.Mes.GetValueOrDefault().ToString("00")
                        </td>
                        <td class="px-2 py-2 whitespace-nowrap text-xs text-gray-500">
                            @item.FechaEmision.GetValueOrDefault().ToString("dd/MM/yy")
                        </td>
                        <td class="px-2 py-2 whitespace-nowrap text-xs text-gray-500">
                            @{
                                var tipo = item.TipoComprobante;
                                string tipoLegible = tipo switch {
                                    "01" => "FC",
                                    "04" => "NC",
                                    "05" => "ND",
                                    _ => tipo ?? ""
                                };
                            }
                            @tipoLegible
                        </td>
                        <td class="px-2 py-2 whitespace-nowrap text-xs text-gray-500">
                            @item.NumComprobante
                        </td>
                        <td class="px-2 py-2 whitespace-nowrap text-xs text-gray-500">
                            @item.IdCliente - @item.RazonSocialCliente
                        </td>
                        <td class="px-2 py-2 whitespace-nowrap text-xs text-right text-gray-900">
                            @item.BaseImponible.GetValueOrDefault().ToString("N2", CultureInfo.InvariantCulture)
                        </td>
                        <td class="px-2 py-2 whitespace-nowrap text-xs text-right text-gray-900">
                            @item.BaseImpGrav.GetValueOrDefault().ToString("N2", CultureInfo.InvariantCulture)
                        </td>
                        <td class="px-2 py-2 whitespace-nowrap text-xs text-right text-gray-900">
                            @item.MontoIva.GetValueOrDefault().ToString("N2", CultureInfo.InvariantCulture)
                        </td>
                        <td class="px-2 py-2 whitespace-nowrap text-xs text-right font-bold text-gray-900">
                            @item.MontoTotal.GetValueOrDefault().ToString("N2", CultureInfo.InvariantCulture)
                        </td>
                        <td class="px-2 py-2 whitespace-nowrap text-right text-xs font-medium">
                            <a asp-page="./Edit" asp-route-id="@item.Id" class="text-indigo-600 hover:text-indigo-900 mr-2">Editar</a>
                            <form method="post" asp-page-handler="Delete" asp-route-id="@item.Id" style="display:inline;" onsubmit="return confirm('Eliminar?');">
                                <button type="submit" class="text-red-600 hover:text-red-900">X</button>
                            </form>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>

@section Scripts {
    <script>
        // Si tienes scripts de validación u otros, irían aquí.
    </script>
}