@page
@model AtsManager.Pages.Ventas.CargaLotesModel

@{
    ViewData["Title"] = "Carga de Lotes de Facturas de Venta";
}

<div class="max-w-xl mx-auto bg-white p-8 rounded-xl shadow-lg">
    <h1 class="text-3xl font-extrabold text-gray-900 mb-6 border-b pb-2">
        Carga de Lotes de Ventas
    </h1>
    <p class="text-gray-500 mb-8">
        Utilice este formulario para cargar masivamente registros de facturas de venta (Archivos `.TXT` o `.TSV`).
    </p>

    @if (!string.IsNullOrEmpty(Model.MensajeProceso))
    {
        <div class="alert @(Model.MensajeProceso.StartsWith("❌") ? "alert-danger" : "alert-success") mb-4" role="alert">
            @Html.Raw(Model.MensajeProceso)
        </div>
    }
    <div asp-validation-summary="All" class="text-sm message-box error"></div>
    @* --- CORRECCIÓN CRÍTICA AQUÍ --- *@
    <form method="post" enctype="multipart/form-data" class="space-y-6" novalidate asp-page-handler="Process">

        <div class="space-y-4">
            <div>
                <label asp-for="RucEmisor" class="block text-sm font-medium text-gray-700">RUC de la Empresa (Emisor)</label>
                <input asp-for="RucEmisor" type="text" maxlength="13" class="mt-1 block w-full rounded-md border-gray-300 shadow-sm p-2" required />
                <span asp-validation-for="RucEmisor" class="text-red-600 text-xs"></span>
            </div>

            <div>
                <label asp-for="ArchivoVentas" class="block text-sm font-medium text-gray-700">Seleccionar Archivo de Ventas</label>
                <input asp-for="ArchivoVentas" type="file" accept=".txt,.tsv" class="mt-1 block w-full text-sm text-gray-500
                        file:mr-4 file:py-2 file:px-4
                        file:rounded-full file:border-0
                        file:text-sm file:font-semibold
                        file:bg-indigo-50 file:text-indigo-700
                        hover:file:bg-indigo-100" required />
                <span asp-validation-for="ArchivoVentas" class="text-red-600 text-xs"></span>
            </div>
        </div>

        <div class="pt-5 flex justify-end">
            <a asp-page="./Index" class="inline-flex items-center px-4 py-2 border border-gray-300 shadow-sm text-sm font-medium rounded-md text-gray-700 bg-white hover:bg-gray-50 mr-3">
                Cancelar
            </a>
            @* Se añade id="submit-btn" para el JS *@
            <button type="submit" id="submit-btn" class="inline-flex justify-center py-2 px-4 border border-transparent shadow-sm text-sm font-medium rounded-md text-white bg-indigo-600 hover:bg-indigo-700 focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-indigo-500 transition duration-150 ease-in-out">
                <i class="fas fa-upload mr-2"></i> Procesar Carga
            </button>
        </div>
    </form>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }

    <script>
        ModelState.Remove("TipoDocumento");

            // Propiedades derivadas del comprobante (SERIE_COMPROBANTE)
            ModelState.Remove("Estab");
            ModelState.Remove("PtoEmi");
            ModelState.Remove("Secuencial");
            ModelState.Remove("NumComprobante"); // Si existe como propiedad separada

            // Propiedades de Venta requeridas que no están en el formulario
            ModelState.Remove("ClaveAcceso");
            ModelState.Remove("FechaAutorizacion"); // Si es un DateTime non-nullable
            ModelState.Remove("BaseNoGraIva");      // Se calcula después

            // Propiedades de auditoría o cálculo (short, int, DateTime non-nullable)
            ModelState.Remove("Anio");
            ModelState.Remove("Mes");
            ModelState.Remove("IdCliente");
            ModelState.Remove("RazonSocialCliente");
            ModelState.Remove("valRetIVA");
            ModelState.Remove("valRetRenta");
            ModelState.Remove("NumRetencion");
            // ... Añada cualquier otra propiedad non-nullable de Venta o CargaLote faltante

            // --- REVISAR AQUÍ ---
            if (!ModelState.IsValid)
            {
                // ...
                return Page();
            }
        // CRÍTICO: Se usa $(function () { ... }) para asegurar que jQuery esté disponible.
        $(function () {
            const form = document.querySelector('form');
            const submitButton = document.getElementById('submit-btn');

            // Función para manejar el estado de carga (Lógica de doble-submit)
            const handleLoadingState = (button) => {
                if (!button) return;

                // SVG Spinner (Tailwind)
                const spinnerHtml = '<svg class="animate-spin -ml-1 mr-3 h-5 w-5 text-white" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24"><circle class="opacity-25" cx="12" cy="12" r="10" stroke="currentColor" stroke-width="4"></circle><path class="opacity-75" fill="currentColor" d="M4 12a8 8 0 018-8V0C5.373 0 0 5.373 0 12h4zm2 5.291A7.962 7.962 0 014 12H0c0 3.042 1.135 5.824 3 7.938l3-2.647z"></path></svg>';

                form.addEventListener('submit', () => {
                    // Solo deshabilitamos si el formulario es considerado válido por jQuery Unobtrusive
                    if ($(form).valid()) {
                        button.disabled = true;
                        button.classList.add('bg-indigo-400', 'cursor-not-allowed');
                        button.innerHTML = spinnerHtml + 'Procesando...';
                    }
                });
            };

            // Ejecutar la lógica de deshabilitar el botón de carga
            if (submitButton) {
                handleLoadingState(submitButton);
            }
        });
    </script>
}