@page
@model AtsManager.Pages.Ventas.CreateVentaModel
@using System.Globalization

<script src="https://cdn.tailwindcss.com"></script>
<style>
    .message-box { padding: 1rem; border-radius: 0.5rem; margin-bottom: 1.5rem; font-weight: 600; }
    .success { background-color: #d1fae5; color: #065f46; border-left: 5px solid #10b981; }
    .error { background-color: #fee2e2; color: #991b1b; border-left: 5px solid #ef4444; }
</style>

<div class="max-w-4xl mx-auto bg-white p-8 rounded-xl shadow-lg">
    <h1 class="text-3xl font-extrabold text-gray-900 mb-6 border-b pb-2">
        Ingresar Venta Manualmente
    </h1>

    <div asp-validation-summary="ModelOnly" class="text-sm message-box error"></div>

    @* --- SECCIÓN DE BÚSQUEDA POR CLAVE DE ACCESO --- *@
    <form method="post" asp-page-handler="BuscarComprobante" class="mb-8 border-2 border-dashed border-indigo-300 p-6 rounded-lg bg-indigo-50">
        <h2 class="text-lg font-semibold text-indigo-800 mb-4">Autollenado por Clave de Acceso</h2>
        <div class="flex space-x-4 items-end">
            <div class="flex-grow">
                <label asp-for="AutorizacionInput" class="block text-sm font-medium text-gray-700">Clave de Acceso (49 dígitos)</label>
                <input asp-for="AutorizacionInput" class="mt-1 block w-full rounded-md border-gray-300 shadow-sm p-2" maxlength="49" />
                <span asp-validation-for="AutorizacionInput" class="text-red-600 text-xs"></span>
            </div>
            <button type="submit" class="h-10 px-4 py-2 text-sm font-medium rounded-md text-white bg-blue-600 hover:bg-blue-700 shadow-sm transition">
                Buscar y Precargar
            </button>
        </div>
        @* Campos ocultos para mantener el estado del modelo mientras se busca *@
        <input type="hidden" asp-for="RegistroVenta.Anio" />
        <input type="hidden" asp-for="RegistroVenta.Mes" />
        <input type="hidden" asp-for="RegistroVenta.IdCliente" />
        <input type="hidden" asp-for="RegistroVenta.NumComprobante" />
        <input type="hidden" asp-for="RegistroVenta.TipoComprobante" />
    </form>
    @* ---------------------------------------------------- *@


    @* --- FORMULARIO DE GUARDADO FINAL --- *@
    <form method="post" class="space-y-6">
        @* Campos ocultos que contienen los valores precargados *@
        <input type="hidden" asp-for="RegistroVenta.Id" />
        <input type="hidden" asp-for="RegistroVenta.FechaCreacion" />
        <input type="hidden" asp-for="RegistroVenta.UsuarioCreacion" />
        <input type="hidden" asp-for="RegistroVenta.TipoComprobante" />
        
        @* -- SECCIÓN EMPRESA (auto-seleccionada) -- *@
        <div class="bg-blue-50 p-6 rounded-lg border border-blue-200">
            <h3 class="text-lg font-semibold text-gray-800 border-b pb-2 mb-4">Empresa Emisora</h3>
            <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
                <div>
                    <label class="block text-sm font-medium text-gray-700">Empresa</label>
                    <input type="text" class="mt-1 block w-full rounded-md bg-gray-100 border-gray-300 shadow-sm p-2 text-gray-700" 
                           value="@Model.CurrentRucPublic - @Model.CurrentNombrePublic" readonly />
                    <input type="hidden" asp-for="EmpresaId" />
                    <span class="text-xs text-gray-500">Empresa global seleccionada automáticamente.</span>
                </div>
            </div>
        </div>

        <div class="bg-indigo-50 p-4 rounded-lg">
            <h2 class="text-lg font-semibold text-indigo-800 mb-4">Período y Datos Básicos</h2>
            <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
                <div>
                    <label asp-for="RegistroVenta.Anio" class="block text-sm font-medium text-gray-700">Año</label>
                    <input asp-for="RegistroVenta.Anio" type="number" class="mt-1 block w-full rounded-md border-gray-300 shadow-sm p-2" required />
                </div>
                <div>
                    <label asp-for="RegistroVenta.Mes" class="block text-sm font-medium text-gray-700">Mes</label>
                    <input asp-for="RegistroVenta.Mes" type="number" class="mt-1 block w-full rounded-md border-gray-300 shadow-sm p-2" required />
                </div>
                <div>
                    <label asp-for="RegistroVenta.FechaEmision" class="block text-sm font-medium text-gray-700">Fecha Emisión</label>
                    <input asp-for="RegistroVenta.FechaEmision" type="date" class="mt-1 block w-full rounded-md border-gray-300 shadow-sm p-2" required readonly />
                </div>
            </div>
        </div>

        <div class="bg-gray-50 p-4 rounded-lg">
            <h2 class="text-lg font-semibold text-gray-800 mb-4">Cliente y Documento</h2>
            <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
                 <div>
                    <label asp-for="RegistroVenta.IdCliente" class="block text-sm font-medium text-gray-700">RUC/ID Cliente</label>
                    <input asp-for="RegistroVenta.IdCliente" class="mt-1 block w-full rounded-md border-gray-300 shadow-sm p-2" required />
                </div>
                <div>
                    <label asp-for="RegistroVenta.NumComprobante" class="block text-sm font-medium text-gray-700">No. Comprobante</label>
                    <input asp-for="RegistroVenta.NumComprobante" class="mt-1 block w-full rounded-md border-gray-300 shadow-sm p-2" required />
                </div>
            </div>
            <div class="mt-6">
                <label asp-for="RegistroVenta.RazonSocialCliente" class="block text-sm font-medium text-gray-700">Razón Social</label>
                <input asp-for="RegistroVenta.RazonSocialCliente" class="mt-1 block w-full rounded-md border-gray-300 shadow-sm p-2" required />
            </div>

            @* DOCUMENTO MODIFICADO (para NC/ND) *@
            <div class="mt-6 bg-blue-50 p-4 rounded-lg border border-blue-200">
                <h3 class="text-sm font-semibold text-blue-800 mb-3">Documento Modificado (para Notas de Crédito/Débito)</h3>
                <div class="grid grid-cols-1 md:grid-cols-5 gap-4">
                    <div>
                        <label asp-for="RegistroVenta.TipoComprobanteModificado" class="block text-xs font-medium text-gray-700">Tipo Doc. Modificado</label>
                        <input asp-for="RegistroVenta.TipoComprobanteModificado" class="mt-1 block w-full rounded border-gray-300 p-2 text-sm" placeholder="01" />
                    </div>
                    <div>
                        <label asp-for="RegistroVenta.EstablecimientoModificado" class="block text-xs font-medium text-gray-700">Estab. Modificado</label>
                        <input asp-for="RegistroVenta.EstablecimientoModificado" class="mt-1 block w-full rounded border-gray-300 p-2 text-sm" placeholder="001" />
                    </div>
                    <div>
                        <label asp-for="RegistroVenta.PuntoEmisionModificado" class="block text-xs font-medium text-gray-700">PtoEmi Modificado</label>
                        <input asp-for="RegistroVenta.PuntoEmisionModificado" class="mt-1 block w-full rounded border-gray-300 p-2 text-sm" placeholder="001" />
                    </div>
                    <div>
                        <label asp-for="RegistroVenta.SecuencialModificado" class="block text-xs font-medium text-gray-700">Secuencial Modificado</label>
                        <input asp-for="RegistroVenta.SecuencialModificado" class="mt-1 block w-full rounded border-gray-300 p-2 text-sm" placeholder="000000001" />
                    </div>
                    <div>
                        <label asp-for="RegistroVenta.AutorizacionModificada" class="block text-xs font-medium text-gray-700">Autorización (37+ dígitos)</label>
                        <input asp-for="RegistroVenta.AutorizacionModificada" class="mt-1 block w-full rounded border-gray-300 p-2 text-sm" placeholder="0010010000000010000000001..." />
                    </div>
                </div>
            </div>
            
        </div>
        
        <div class="bg-yellow-50 p-4 rounded-lg">
            <h2 class="text-lg font-semibold text-yellow-800 mb-4">Bases y Montos (Manual)</h2>
            <p class="text-sm text-yellow-700 mb-4">Asegúrese de que el **Monto Total** cuadre con las bases y el IVA.</p>
            <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
                <div><label asp-for="RegistroVenta.BaseImponible" class="block text-sm font-medium text-gray-700">Base 12%</label><input asp-for="RegistroVenta.BaseImponible" type="number" step="0.01" class="mt-1 block w-full rounded-md border-gray-300 shadow-sm p-2 text-right" required /></div>
                <div><label asp-for="RegistroVenta.BaseImpGrav" class="block text-sm font-medium text-gray-700">Base 0%</label><input asp-for="RegistroVenta.BaseImpGrav" type="number" step="0.01" class="mt-1 block w-full rounded-md border-gray-300 shadow-sm p-2 text-right" required /></div>
                <div><label asp-for="RegistroVenta.BaseNoGraIva" class="block text-sm font-medium text-gray-700">Base No Objeto</label><input asp-for="RegistroVenta.BaseNoGraIva" type="number" step="0.01" class="mt-1 block w-full rounded-md border-gray-300 shadow-sm p-2 text-right" required /></div>
                
                <div><label asp-for="RegistroVenta.MontoIva" class="block text-sm font-medium text-gray-700">Monto IVA</label><input asp-for="RegistroVenta.MontoIva" type="number" step="0.01" class="mt-1 block w-full rounded-md border-gray-300 shadow-sm p-2 text-right" required /></div>
                <div><label asp-for="RegistroVenta.MontoIce" class="block text-sm font-medium text-gray-700">Monto ICE</label><input asp-for="RegistroVenta.MontoIce" type="number" step="0.01" class="mt-1 block w-full rounded-md border-gray-300 shadow-sm p-2 text-right" required /></div>
                <div><label asp-for="RegistroVenta.MontoTotal" class="block text-sm font-medium text-gray-700">Monto Total</label><input asp-for="RegistroVenta.MontoTotal" type="number" step="0.01" class="mt-1 block w-full rounded-md border-gray-300 shadow-sm p-2 text-right" required /></div>
            </div>
        </div>

        <div class="pt-5">
            <button type="submit" class="w-full inline-flex justify-center py-3 px-4 border border-transparent shadow-sm text-sm font-medium rounded-md text-white bg-indigo-600 hover:bg-indigo-700 focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-indigo-500 transition duration-150 ease-in-out">
                Guardar Registro de Venta
            </button>
        </div>
    </form>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}