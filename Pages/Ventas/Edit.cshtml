@page
@model AtsManager.Pages.Ventas.EditModel
@using System.Globalization

<div class="max-w-6xl mx-auto bg-white p-6 rounded-xl shadow-lg">
    <h1 class="text-2xl font-extrabold text-gray-900 mb-4 border-b pb-2">
        Editar Venta
    </h1>

    @if (!string.IsNullOrEmpty(Model.MensajeProceso))
    {
        <div class="alert alert-warning text-sm message-box error mb-4">
            @Html.Raw(Model.MensajeProceso)
        </div>
    }

    <div asp-validation-summary="ModelOnly" class="text-sm message-box error mb-4"></div>

    <form method="post" class="space-y-4">
        <input type="hidden" asp-for="Venta.Id" />
        <input type="hidden" asp-for="Venta.CargaLoteId" />
        <input type="hidden" asp-for="Venta.RucEmpresa" />

        @* PERIODO Y DOCUMENTO *@
        <div class="bg-indigo-50 p-4 rounded-lg">
            <h2 class="text-base font-semibold text-indigo-800 mb-3">Período y Documento</h2>
            <div class="grid grid-cols-2 md:grid-cols-6 gap-3">
                <div>
                    <label asp-for="Venta.Anio" class="block text-xs font-medium text-gray-700">Año</label>
                    <input asp-for="Venta.Anio" type="number" class="w-full rounded border-gray-300 p-1 text-sm" required />
                </div>
                <div>
                    <label asp-for="Venta.Mes" class="block text-xs font-medium text-gray-700">Mes</label>
                    <input asp-for="Venta.Mes" type="number" class="w-full rounded border-gray-300 p-1 text-sm" required />
                </div>
                <div>
                    <label asp-for="Venta.TipoComprobante" class="block text-xs font-medium text-gray-700">Tipo Doc</label>
                    <input asp-for="Venta.TipoComprobante" class="w-full rounded border-gray-300 p-1 text-sm" />
                </div>
                <div>
                    <label asp-for="Venta.Estab" class="block text-xs font-medium text-gray-700">Estab.</label>
                    <input asp-for="Venta.Estab" class="w-full rounded border-gray-300 p-1 text-sm" />
                </div>
                <div>
                    <label asp-for="Venta.PtoEmi" class="block text-xs font-medium text-gray-700">PtoEmi</label>
                    <input asp-for="Venta.PtoEmi" class="w-full rounded border-gray-300 p-1 text-sm" />
                </div>
                <div>
                    <label asp-for="Venta.Secuencial" class="block text-xs font-medium text-gray-700">Secuencial</label>
                    <input asp-for="Venta.Secuencial" class="w-full rounded border-gray-300 p-1 text-sm" />
                </div>
            </div>
            <div class="grid grid-cols-2 md:grid-cols-4 gap-3 mt-3">
                <div>
                    <label asp-for="Venta.NumComprobante" class="block text-xs font-medium text-gray-700">Num. Comprobante</label>
                    <input asp-for="Venta.NumComprobante" class="w-full rounded border-gray-300 p-1 text-sm" />
                </div>
                <div>
                    <label asp-for="Venta.FechaEmision" class="block text-xs font-medium text-gray-700">Fecha Emisión</label>
                    <input asp-for="Venta.FechaEmision" type="date" class="w-full rounded border-gray-300 p-1 text-sm" />
                </div>
                <div>
                    <label asp-for="Venta.FormaPago" class="block text-xs font-medium text-gray-700">Forma Pago</label>
                    <input asp-for="Venta.FormaPago" class="w-full rounded border-gray-300 p-1 text-sm" placeholder="20" />
                </div>
                <div>
                    <label asp-for="Venta.TipoIdCliente" class="block text-xs font-medium text-gray-700">Tipo ID Cliente</label>
                    <input asp-for="Venta.TipoIdCliente" class="w-full rounded border-gray-300 p-1 text-sm" />
                </div>
            </div>
        </div>

        @* CLIENTE *@
        <div class="bg-gray-50 p-4 rounded-lg">
            <h2 class="text-base font-semibold text-gray-800 mb-3">Cliente</h2>
            <div class="grid grid-cols-2 md:grid-cols-4 gap-3">
                <div>
                    <label asp-for="Venta.IdCliente" class="block text-xs font-medium text-gray-700">ID Cliente</label>
                    <input asp-for="Venta.IdCliente" class="w-full rounded border-gray-300 p-1 text-sm" required />
                </div>
                <div class="col-span-3">
                    <label asp-for="Venta.RazonSocialCliente" class="block text-xs font-medium text-gray-700">Razón Social</label>
                    <input asp-for="Venta.RazonSocialCliente" class="w-full rounded border-gray-300 p-1 text-sm" required />
                </div>
            </div>
        </div>

        @* BASES E IMPUESTOS - CON CALCULO AUTOMATICO *@
        <div class="bg-yellow-50 p-4 rounded-lg">
            <h2 class="text-base font-semibold text-yellow-800 mb-3">Bases e Impuestos</h2>
            <div class="grid grid-cols-2 md:grid-cols-5 gap-3">
                <div>
                    <label class="block text-xs font-medium text-gray-700">Base 0% (No Gravada)</label>
                    <input type="number" step="0.01" id="BaseImponible" name="Venta.BaseImponible" value="@Model.Venta.BaseImponible" class="w-full rounded border-gray-300 p-1 text-sm text-right" oninput="calcularTotales()" />
                </div>
                <div>
                    <label class="block text-xs font-medium text-gray-700">Base 12%/15% (Gravada)</label>
                    <input type="number" step="0.01" id="BaseImpGrav" name="Venta.BaseImpGrav" value="@Model.Venta.BaseImpGrav" class="w-full rounded border-gray-300 p-1 text-sm text-right" oninput="calcularTotales()" />
                </div>
                <div>
                    <label class="block text-xs font-medium text-gray-700">IVA (15%)</label>
                    <input type="number" step="0.01" id="MontoIva" name="Venta.MontoIva" value="@Model.Venta.MontoIva" class="w-full rounded border-gray-300 p-1 text-sm text-right" readonly />
                </div>
                <div>
                    <label class="block text-xs font-medium text-gray-700">ICE</label>
                    <input type="number" step="0.01" id="MontoIce" name="Venta.MontoIce" value="@Model.Venta.MontoIce" class="w-full rounded border-gray-300 p-1 text-sm text-right" />
                </div>
                <div>
                    <label class="block text-xs font-medium text-gray-700 font-bold">TOTAL</label>
                    <input type="number" step="0.01" id="MontoTotal" name="Venta.MontoTotal" value="@Model.Venta.MontoTotal" class="w-full rounded border-gray-300 p-1 text-sm text-right font-bold" readonly />
                </div>
            </div>
        </div>

        @* RETENCIONES *@
        <div class="bg-red-50 p-4 rounded-lg">
            <h2 class="text-base font-semibold text-red-800 mb-3">Retenciones</h2>
            @if (Model.Venta.CargaLoteId.HasValue)
            {
                <div class="text-sm text-red-600 mb-3 p-2 bg-red-100 rounded">
                    Esta venta tiene retención asociada al Lote @Model.Venta.CargaLoteId
                </div>
            }
            <div class="grid grid-cols-2 md:grid-cols-4 gap-3">
                <div>
                    <label asp-for="Venta.NumRetencion" class="block text-xs font-medium text-gray-700">Num. Retención</label>
                    <input asp-for="Venta.NumRetencion" class="w-full rounded border-gray-300 p-1 text-sm" />
                </div>
                <div>
                    <label asp-for="Venta.FechaRetencion" class="block text-xs font-medium text-gray-700">Fecha Ret.</label>
                    <input asp-for="Venta.FechaRetencion" type="date" class="w-full rounded border-gray-300 p-1 text-sm" />
                </div>
                <div>
                    <label asp-for="Venta.valRetRenta" class="block text-xs font-medium text-gray-700">Ret. Renta</label>
                    <input asp-for="Venta.valRetRenta" type="number" step="0.01" class="w-full rounded border-gray-300 p-1 text-sm" />
                </div>
                <div>
                    <label asp-for="Venta.valRetIVA" class="block text-xs font-medium text-gray-700">Ret. IVA</label>
                    <input asp-for="Venta.valRetIVA" type="number" step="0.01" class="w-full rounded border-gray-300 p-1 text-sm" />
                </div>
            </div>
        </div>

        <div class="flex justify-between pt-4">
            <a asp-page="./Index" class="px-4 py-2 border border-gray-300 rounded text-gray-700 hover:bg-gray-50 text-sm">Cancelar</a>
            <button type="submit" class="px-4 py-2 bg-indigo-600 text-white rounded hover:bg-indigo-700 text-sm">Actualizar</button>
        </div>
    </form>
</div>

@section Scripts {
    <script>
        function calcularTotales() {
            var baseImponible = parseFloat(document.getElementById('BaseImponible').value) || 0;
            var baseImpGrav = parseFloat(document.getElementById('BaseImpGrav').value) || 0;
            var montoIce = parseFloat(document.getElementById('MontoIce').value) || 0;
            
            // Calcular IVA al 15%
            var iva = Math.round(baseImpGrav * 0.15 * 100) / 100;
            
            // Calcular Total
            var total = baseImponible + baseImpGrav + iva + montoIce;
            
            // Asignar valores
            document.getElementById('MontoIva').value = iva.toFixed(2);
            document.getElementById('MontoTotal').value = total.toFixed(2);
        }
        
        // Calcular al cargar la pagina
        window.onload = calcularTotales;
    </script>
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}
