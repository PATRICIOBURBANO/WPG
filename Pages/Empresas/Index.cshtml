@page
@model AtsManager.Pages.Empresas.IndexModel

<script src="https://cdn.tailwindcss.com"></script>

<div class="w-full px-2 py-4">
    <h1 class="text-2xl font-extrabold text-gray-900 mb-4">Administracion de Empresas</h1>
    <p class="text-gray-500 mb-4">Gestion las empresas/empresas emisoras para el ATS.</p>

    @if (!string.IsNullOrEmpty(Model.Mensaje))
    {
        <div class="mb-4 p-3 rounded-lg @(Model.Mensaje.Contains("ERROR") ? "bg-red-100 text-red-800" : "bg-green-100 text-green-800")">
            @Model.Mensaje
        </div>
    }

    <form method="post" class="mb-6 bg-white p-4 rounded-lg shadow">
        <div class="grid grid-cols-1 md:grid-cols-5 gap-4">
            <div>
                <label class="block text-xs font-medium text-gray-700">RUC</label>
                <input asp-for="NuevaEmpresa.Ruc" class="w-full rounded border-gray-300 text-sm" placeholder="1792468264001" />
            </div>
            <div>
                <label class="block text-xs font-medium text-gray-700">Razon Social</label>
                <input asp-for="NuevaEmpresa.RazonSocial" class="w-full rounded border-gray-300 text-sm" placeholder="EMPRESA S.A." />
            </div>
            <div>
                <label class="block text-xs font-medium text-gray-700">Establecimiento</label>
                <input asp-for="NuevaEmpresa.CodEstablecimiento" class="w-full rounded border-gray-300 text-sm" placeholder="001" />
            </div>
            <div>
                <label class="block text-xs font-medium text-gray-700">Direccion</label>
                <input asp-for="NuevaEmpresa.Direccion" class="w-full rounded border-gray-300 text-sm" />
            </div>
            <div class="flex items-end">
                <div class="flex items-center mb-2">
                    <input asp-for="NuevaEmpresa.Activa" type="checkbox" class="h-4 w-4 text-indigo-600 border-gray-300 rounded" />
                    <label class="ml-2 text-sm text-gray-700">Activa</label>
                </div>
                <button type="submit" class="ml-4 bg-indigo-600 text-white px-4 py-2 rounded text-sm hover:bg-indigo-700">Agregar</button>
            </div>
        </div>
    </form>

    <div class="bg-white rounded-lg shadow overflow-hidden">
        <table class="min-w-full divide-y divide-gray-200">
            <thead class="bg-gray-50">
                <tr>
                    <th class="px-2 py-2 text-left text-xs font-medium text-gray-500 uppercase">RUC</th>
                    <th class="px-2 py-2 text-left text-xs font-medium text-gray-500 uppercase">Razon Social</th>
                    <th class="px-2 py-2 text-left text-xs font-medium text-gray-500 uppercase">Estab</th>
                    <th class="px-2 py-2 text-left text-xs font-medium text-gray-500 uppercase">Estado</th>
                    <th class="px-2 py-2 text-left text-xs font-medium text-gray-500 uppercase">Acciones</th>
                </tr>
            </thead>
            <tbody class="bg-white divide-y divide-gray-200">
                @foreach (var empresa in Model.Empresas)
                {
                    <tr class="hover:bg-gray-50">
                        <td class="px-2 py-2 text-xs">@empresa.Ruc</td>
                        <td class="px-2 py-2 text-xs">@empresa.RazonSocial</td>
                        <td class="px-2 py-2 text-xs">@empresa.CodEstablecimiento</td>
                        <td class="px-2 py-2">
                            <span class="px-2 py-1 text-xs font-semibold rounded-full @(empresa.Activa ? "bg-green-100 text-green-800" : "bg-gray-100 text-gray-800")">
                                @(empresa.Activa ? "Activa" : "Inactiva")
                            </span>
                        </td>
                        <td class="px-2 py-2">
                            <button onclick="editarEmpresa('@empresa.Id', '@empresa.Ruc', '@empresa.RazonSocial', '@empresa.Direccion', '@empresa.CodEstablecimiento', '@empresa.Activa')" class="bg-indigo-500 hover:bg-indigo-700 text-white px-2 py-1 rounded text-xs mr-1">Editar</button>
                            <form method="post" asp-page-handler="Delete" asp-route-id="@empresa.Id" style="display:inline;" onsubmit="return confirm('Esta seguro de eliminar?');">
                                <button type="submit" class="bg-red-500 hover:bg-red-700 text-white px-2 py-1 rounded text-xs">Eliminar</button>
                            </form>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>

<!-- Modal de Edición -->
<div id="editModal" class="fixed inset-0 bg-gray-600 bg-opacity-50 hidden overflow-y-auto h-full w-full z-50">
    <div class="relative top-20 mx-auto p-5 border w-96 shadow-lg rounded-md bg-white">
        <h3 class="text-lg font-medium text-gray-900 mb-4">Editar Empresa</h3>
        <form method="post" asp-page-handler="Editar">
            <input type="hidden" id="editId" name="id" />
            <div class="space-y-3">
                <div>
                    <label class="block text-sm font-medium text-gray-700">RUC</label>
                    <input id="editRuc" name="NuevaEmpresa.Ruc" class="w-full rounded border-gray-300 text-sm" />
                </div>
                <div>
                    <label class="block text-sm font-medium text-gray-700">Razón Social</label>
                    <input id="editRazonSocial" name="NuevaEmpresa.RazonSocial" class="w-full rounded border-gray-300 text-sm" />
                </div>
                <div>
                    <label class="block text-sm font-medium text-gray-700">Dirección</label>
                    <input id="editDireccion" name="NuevaEmpresa.Direccion" class="w-full rounded border-gray-300 text-sm" />
                </div>
                <div>
                    <label class="block text-sm font-medium text-gray-700">Código Establecimiento</label>
                    <input id="editEstablecimiento" name="NuevaEmpresa.CodEstablecimiento" class="w-full rounded border-gray-300 text-sm" />
                </div>
                <div class="flex items-center">
                    <input type="hidden" name="EmpresaActiva" value="false" />
                    <input id="editActiva" name="EmpresaActiva" type="checkbox" value="true" class="h-4 w-4 text-indigo-600 border-gray-300 rounded" />
                    <label class="ml-2 text-sm text-gray-900">Empresa Activa</label>
                </div>
            </div>
            <div class="flex justify-end gap-2 mt-4">
                <button type="button" onclick="cerrarModal()" class="px-3 py-2 bg-gray-300 text-gray-700 rounded text-sm hover:bg-gray-400">Cancelar</button>
                <button type="submit" class="px-3 py-2 bg-indigo-600 text-white rounded text-sm hover:bg-indigo-700">Guardar</button>
            </div>
        </form>
    </div>
</div>

<script>
    function editarEmpresa(id, ruc, razonSocial, direccion, establecimiento, activa) {
        document.getElementById('editId').value = id;
        document.getElementById('editRuc').value = ruc;
        document.getElementById('editRazonSocial').value = razonSocial;
        document.getElementById('editDireccion').value = direccion || '';
        document.getElementById('editEstablecimiento').value = establecimiento || '';
        document.getElementById('editActiva').checked = activa === 'True';
        document.getElementById('editModal').classList.remove('hidden');
    }
    
    function cerrarModal() {
        document.getElementById('editModal').classList.add('hidden');
    }
</script>
