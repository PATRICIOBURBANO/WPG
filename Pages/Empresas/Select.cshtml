@page "/Empresas/Select"
@model AtsManager.Pages.Empresas.SelectModel
@{
    Layout = null;
}

<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Seleccionar Empresa - ATS Manager</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
</head>
<body class="bg-gray-100 min-h-screen">
    <div class="max-w-7xl mx-auto px-4 py-6">
        <!-- Dashboard-style header -->
        <div class="mb-8">
            <h1 class="text-2xl font-bold text-gray-900">ATS Manager</h1>
            <p class="text-gray-500 text-sm">Seleccione la empresa para comenzar</p>
        </div>

        <div class="max-w-lg mx-auto">
            @if (Model.Empresas.Count == 0)
            {
                <div class="bg-white rounded-xl shadow-sm border border-gray-200 p-8 text-center">
                    <div class="inline-flex items-center justify-center w-16 h-16 bg-gray-100 rounded-full mb-4">
                        <i class="fas fa-building text-3xl text-gray-400"></i>
                    </div>
                    <h3 class="text-lg font-medium text-gray-900 mb-2">No hay empresas registradas</h3>
                    <p class="text-gray-500 mb-6">Agregue una empresa para comenzar a usar el sistema.</p>
                    <a href="/Empresas/Index" class="inline-flex items-center px-4 py-2 bg-indigo-600 text-white rounded-lg hover:bg-indigo-700 font-medium transition-colors">
                        <i class="fas fa-plus mr-2"></i>Agregar Empresa
                    </a>
                </div>
            }
            else
            {
                <div class="space-y-2">
                    @foreach (var emp in Model.Empresas)
                    {
                        var isSelected = emp.Ruc == Model.EmpresaActual;
                        <a href="/Empresas/Set?ruc=@emp.Ruc&returnUrl=@Uri.EscapeDataString(Model.ReturnUrl)"
                           class="block px-6 py-4 bg-white rounded-xl border-2 transition-all @(isSelected ? "border-indigo-500 bg-indigo-50 shadow-md" : "border-gray-200 shadow-sm hover:border-indigo-400 hover:bg-indigo-50 hover:shadow-md")">
                            <div class="flex items-center justify-between">
                                <div>
                                    <div class="font-semibold text-gray-900 text-lg">@emp.RazonSocial</div>
                                    <div class="text-sm text-gray-500 flex items-center mt-1">
                                        <i class="fas fa-id-card mr-2 text-gray-400"></i>@emp.Ruc
                                    </div>
                                </div>
                                @if (isSelected)
                                {
                                    <span class="px-3 py-1 bg-indigo-600 text-white text-xs font-semibold rounded-full">
                                        <i class="fas fa-check mr-1"></i>Seleccionada
                                    </span>
                                }
                                else
                                {
                                    <i class="fas fa-chevron-right text-gray-300 group-hover:text-indigo-500 transition-colors"></i>
                                }
                            </div>
                        </a>
                    }
                </div>
            }

            <div class="mt-6 text-center">
                <a href="/Empresas/Index" class="inline-flex items-center text-indigo-600 hover:text-indigo-800 text-sm font-medium transition-colors">
                    <i class="fas fa-cog mr-2"></i>+ Agregar / Editar Empresas
                </a>
            </div>
        </div>
    </div>
</body>
</html>
