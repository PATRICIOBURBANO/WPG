@page
@model AtsManager.Pages.Empresas.SelectorModel
@using AtsManager.Models
@{
    Layout = null;
}

<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Seleccionar Empresa - ATS Manager</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
    <style>
        body { font-family: 'Inter', sans-serif; }
        .company-card:hover { transform: translateY(-4px); box-shadow: 0 12px 24px -8px rgba(99, 102, 241, 0.3); }
    </style>
</head>
<body class="bg-gradient-to-br from-indigo-900 via-indigo-800 to-purple-900 min-h-screen flex items-center justify-center p-4">
    <div class="w-full max-w-5xl">
        <div class="text-center mb-8">
            <div class="inline-flex items-center justify-center w-20 h-20 bg-white/20 backdrop-blur rounded-2xl mb-6">
                <i class="fas fa-building text-white text-4xl"></i>
            </div>
            <h1 class="text-3xl md:text-4xl font-bold text-white mb-2">ATS Manager</h1>
            <p class="text-indigo-200 text-lg">Seleccione la empresa con la que desea trabajar</p>
        </div>

        @if (Model.Empresas.Any())
        {
            <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
                @foreach (var empresa in Model.Empresas)
                {
                    <form method="post" asp-page-handler="SelectCompany" asp-antiforgery="true" class="inline">
                        <input type="hidden" name="ruc" value="@empresa.Ruc" />
                        <input type="hidden" name="returnUrl" value="@Model.ReturnUrl" />
                        <button type="submit" class="company-card w-full text-left bg-white/95 backdrop-blur rounded-xl p-6 shadow-lg transition-all duration-300 hover:bg-white border-2 border-transparent hover:border-indigo-400">
                            <div class="flex items-start justify-between mb-4">
                                <div class="bg-indigo-100 p-3 rounded-lg">
                                    <i class="fas fa-building text-indigo-600 text-2xl"></i>
                                </div>
                                @if (empresa.Activa)
                                {
                                    <span class="bg-green-100 text-green-700 text-xs font-semibold px-2 py-1 rounded-full">
                                        <i class="fas fa-check-circle mr-1"></i>Activa
                                    </span>
                                }
                                else
                                {
                                    <span class="bg-gray-100 text-gray-600 text-xs font-semibold px-2 py-1 rounded-full">
                                        Inactiva
                                    </span>
                                }
                            </div>
                            <h3 class="text-lg font-bold text-gray-900 mb-1 line-clamp-2">@empresa.RazonSocial</h3>
                            <p class="text-gray-500 text-sm mb-3">@empresa.Ruc</p>
                            @if (!string.IsNullOrEmpty(empresa.Direccion))
                            {
                                <p class="text-gray-400 text-xs mb-2">
                                    <i class="fas fa-map-marker-alt mr-1"></i>@empresa.Direccion
                                </p>
                            }
                            <div class="flex items-center text-indigo-600 font-medium text-sm">
                                <span>Seleccionar</span>
                                <i class="fas fa-arrow-right ml-2"></i>
                            </div>
                        </button>
                    </form>
                }
            </div>
        }
        else
        {
            <div class="bg-white/10 backdrop-blur rounded-xl p-8 text-center">
                <i class="fas fa-exclamation-triangle text-yellow-400 text-5xl mb-4"></i>
                <h2 class="text-xl font-semibold text-white mb-2">No hay empresas registradas</h2>
                <p class="text-indigo-200 mb-6">Primero debe registrar al menos una empresa para continuar.</p>
                <a href="/Empresas/Index" class="inline-flex items-center bg-white text-indigo-600 px-6 py-3 rounded-lg font-semibold hover:bg-indigo-50 transition-colors">
                    <i class="fas fa-plus mr-2"></i>Registrar Empresa
                </a>
            </div>
        }

        <div class="text-center mt-8">
            <a href="/Empresas/Index" class="text-indigo-200 hover:text-white transition-colors text-sm">
                <i class="fas fa-plus mr-1"></i>Agregar nueva empresa
            </a>
        </div>
    </div>
</body>
</html>
