@page
@model AtsManager.Pages.Compras.CreateCompraModel
@using System.Globalization

@{
    // Lógica para determinar si los campos clave deben ser de solo lectura (si ya se precargaron)
    bool isDateReadOnly = !string.IsNullOrEmpty(Model.RegistroCompra.Autorizacion)
                          && Model.RegistroCompra.Autorizacion.Length == 49;

    // Helper para formatear la fecha
    string fechaEmisionValue = Model.RegistroCompra.FechaEmision.HasValue
        ? Model.RegistroCompra.FechaEmision.Value.ToString("yyyy-MM-dd")
        : "";
}

<script src="https://cdn.tailwindcss.com"></script>

<style>
    .message-box {
        padding: 1rem;
        border-radius: 0.5rem;
        margin-bottom: 1.5rem;
        font-weight: 600;
    }

    .success {
        background-color: #d1fae5;
        color: #065f46;
        border-left: 5px solid #10b981;
    }

    .error {
        background-color: #fee2e2;
        color: #991b1b;
        border-left: 5px solid #ef4444;
    }

    .input-readonly {
        background-color: #f3f4f6;
        cursor: not-allowed;
        color: #6b7280;
    }

    .input-calculado {
        background-color: #ecfdf5;
        border-color: #34d399;
        font-weight: 600;
    }

    .input-total {
        background-color: #eff6ff;
        border-color: #60a5fa;
        font-weight: 800;
        color: #1e3a8a;
        font-size: 1.1rem;
    }
</style>

<div class="max-w-5xl mx-auto bg-white p-8 rounded-xl shadow-lg">
    <h1 class="text-3xl font-extrabold text-gray-900 mb-6 border-b pb-2">
        Ingresar Compra Manualmente
    </h1>

    @* Mensajes del Sistema *@
    @if (TempData["MensajeExito"] != null)
    {
        <div class="message-box success mb-6">
            @TempData["MensajeExito"]
        </div>
    }

    <div asp-validation-summary="ModelOnly" class="text-sm message-box error"></div>

    @* --- SECCIÓN DE BÚSQUEDA POR CLAVE DE ACCESO --- *@
    <form method="post" asp-page-handler="BuscarComprobante" class="mb-8 border-2 border-dashed border-indigo-300 p-6 rounded-lg bg-indigo-50" onsubmit="return validarLongitudClave()">
        <h2 class="text-lg font-semibold text-indigo-800 mb-4">Autollenado por Clave de Acceso</h2>
        <div class="flex gap-4 items-end">
            <div class="flex-grow">
                <label asp-for="AutorizacionInput" class="block text-sm font-medium text-gray-700">Clave de Acceso (49 dígitos)</label>
                <input asp-for="AutorizacionInput" id="txtAutorizacionInput" class="mt-1 block w-full rounded-md border-gray-300 shadow-sm p-2 focus:ring-indigo-500 focus:border-indigo-500" maxlength="49" placeholder="Pegue aquí la clave..." />
                <span asp-validation-for="AutorizacionInput" id="valAutorizacionInput" class="text-red-600 text-xs"></span>
            </div>
            <button type="submit" class="h-10 px-6 py-2 text-sm font-medium rounded-md text-white bg-indigo-600 hover:bg-indigo-700 shadow-sm transition">
                Buscar y Precargar
            </button>
        </div>
        @* Preservar datos si la búsqueda falla *@
        <input type="hidden" asp-for="RegistroCompra.Anio" />
        <input type="hidden" asp-for="RegistroCompra.Mes" />
        <input type="hidden" asp-for="RegistroCompra.IdProveedor" />
        <input type="hidden" asp-for="RegistroCompra.NumComprobante" />
        <input type="hidden" asp-for="RegistroCompra.Autorizacion" />
    </form>


    @* --- FORMULARIO PRINCIPAL --- *@
    <form method="post" class="space-y-6" onsubmit="return confirmarGuardado()">

        @* Campos Ocultos Críticos *@
        <input type="hidden" asp-for="RegistroCompra.Id" />
        <input type="hidden" asp-for="RegistroCompra.FechaCreacion" />
        <input type="hidden" asp-for="RegistroCompra.UsuarioCreacion" />
        <input type="hidden" asp-for="RegistroCompra.CargaLoteId" />

        @* Los valores reales viajan en hidden para los campos readonly *@
        <input type="hidden" asp-for="RegistroCompra.Autorizacion" />
        <input type="hidden" asp-for="RegistroCompra.NumComprobante" />
        <input type="hidden" asp-for="RegistroCompra.IdProveedor" />
        <input type="hidden" asp-for="RegistroCompra.Anio" />
        <input type="hidden" asp-for="RegistroCompra.Mes" />

        @* -- SECCIÓN A: DATOS DE CABECERA -- *@
        <div class="bg-gray-50 p-6 rounded-lg border border-gray-200">
            <h3 class="text-lg font-semibold text-gray-800 border-b pb-2 mb-4">Datos del Documento</h3>

            <div class="grid grid-cols-1 md:grid-cols-3 gap-6 mb-4">
                @* Año (Visual) *@
                <div>
                    <label class="block text-xs font-bold text-gray-700 uppercase">Año</label>
                    <input value="@Model.RegistroCompra.Anio" class="mt-1 block w-full rounded border-gray-300 p-2 input-readonly" readonly />
                </div>
                @* Mes (Visual) *@
                <div>
                    <label class="block text-xs font-bold text-gray-700 uppercase">Mes</label>
                    <input value="@Model.RegistroCompra.Mes" class="mt-1 block w-full rounded border-gray-300 p-2 input-readonly" readonly />
                </div>
                @* Fecha Emisión *@
                <div>
                    <label asp-for="RegistroCompra.FechaEmision" class="block text-xs font-bold text-gray-700 uppercase">Fecha Emisión</label>
                    <input asp-for="RegistroCompra.FechaEmision" type="date"
                           class="mt-1 block w-full rounded border-gray-300 p-2 @(isDateReadOnly ? "input-readonly" : "")"
                           readonly="@(isDateReadOnly)" required value="@fechaEmisionValue" />
                    <span asp-validation-for="RegistroCompra.FechaEmision" class="text-red-500 text-xs"></span>
                </div>
            </div>

            <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
                <div>
                    <label class="block text-xs font-bold text-gray-700 uppercase">RUC / ID Proveedor</label>
                    @* Input visual readonly *@
                    <input value="@Model.RegistroCompra.IdProveedor" class="mt-1 block w-full rounded border-gray-300 p-2 input-readonly" disabled />
                </div>
                <div>
                    <label class="block text-xs font-bold text-gray-700 uppercase">Nro. Comprobante</label>
                    @* Input visual readonly *@
                    <input value="@Model.RegistroCompra.NumComprobante" class="mt-1 block w-full rounded border-gray-300 p-2 input-readonly" disabled />
                </div>
            </div>

            <div class="mt-4">
                <label asp-for="RegistroCompra.RazonSocialProveedor" class="block text-xs font-bold text-gray-700 uppercase">Razón Social</label>
                <input asp-for="RegistroCompra.RazonSocialProveedor" id="RegistroCompra_RazonSocialProveedor" class="mt-1 block w-full rounded border-gray-300 p-2 uppercase" required />
                <span asp-validation-for="RegistroCompra.RazonSocialProveedor" class="text-red-500 text-xs"></span>
            </div>

            <div class="mt-4">
                <label asp-for="RegistroCompra.TipoComprobante" class="block text-xs font-bold text-gray-700 uppercase">Tipo Comprobante</label>
                <select asp-for="RegistroCompra.TipoComprobante" class="mt-1 block w-full rounded border-gray-300 p-2 bg-white">
                    <option value="01">01 - FACTURA</option>
                    <option value="02">02 - NOTA DE VENTA</option>
                    <option value="03">03 - LIQ. COMPRA</option>
                    <option value="04">04 - NOTA DE CRÉDITO</option>
                    <option value="05">05 - NOTA DE DÉBITO</option>
                </select>
            </div>

            @* DOCUMENTO MODIFICADO (para NC/ND) - Solo visible cuando es NC o ND *@
            <div id="seccionDocModificado" class="mt-4 bg-blue-50 p-4 rounded-lg border border-blue-200" style="display:none;">
                <h4 class="text-sm font-semibold text-blue-800 mb-3">Documento Modificado (para Notas de Crédito/Débito)</h4>
                <div class="grid grid-cols-1 md:grid-cols-5 gap-4">
                    <div>
                        <label asp-for="RegistroCompra.TipoComprobanteModificado" class="block text-xs font-medium text-gray-700">Tipo Doc. Modificado</label>
                        <input asp-for="RegistroCompra.TipoComprobanteModificado" class="mt-1 block w-full rounded border-gray-300 p-2 text-sm" placeholder="01" />
                    </div>
                    <div>
                        <label asp-for="RegistroCompra.EstablecimientoModificado" class="block text-xs font-medium text-gray-700">Estab. Modificado</label>
                        <input asp-for="RegistroCompra.EstablecimientoModificado" class="mt-1 block w-full rounded border-gray-300 p-2 text-sm" placeholder="001" />
                    </div>
                    <div>
                        <label asp-for="RegistroCompra.PuntoEmisionModificado" class="block text-xs font-medium text-gray-700">PtoEmi Modificado</label>
                        <input asp-for="RegistroCompra.PuntoEmisionModificado" class="mt-1 block w-full rounded border-gray-300 p-2 text-sm" placeholder="001" />
                    </div>
                    <div>
                        <label asp-for="RegistroCompra.SecuencialModificado" class="block text-xs font-medium text-gray-700">Secuencial Modificado</label>
                        <input asp-for="RegistroCompra.SecuencialModificado" class="mt-1 block w-full rounded border-gray-300 p-2 text-sm" placeholder="000000001" />
                    </div>
                    <div>
                        <label asp-for="RegistroCompra.AutorizacionModificada" class="block text-xs font-medium text-gray-700">Autorización (37+ dígitos)</label>
                        <input asp-for="RegistroCompra.AutorizacionModificada" class="mt-1 block w-full rounded border-gray-300 p-2 text-sm" placeholder="0010010000000010000000001..." />
                    </div>
                </div>
            </div>
        </div>

        @* -- SECCIÓN B: VALORES ECONÓMICOS -- *@
        <div class="bg-yellow-50 p-6 rounded-lg border border-yellow-200 space-y-5">
            <h3 class="text-lg font-semibold text-yellow-800 border-b border-yellow-300 pb-2 mb-4">Valores Económicos</h3>
            <p class="text-sm text-yellow-700">Ingrese los valores. El IVA se calcula con la base 15% y el Total se actualiza.</p>

            <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
                @* BASE 15% *@
                <div>
                    <label asp-for="RegistroCompra.BaseImponible" class="block text-xs font-bold text-green-700 uppercase">Base Imponible (15%)</label>
                    <input asp-for="RegistroCompra.BaseImponible" id="txtBaseGrav" type="number" step="0.01"
                           class="mt-1 block w-full rounded border-green-300 p-2 text-right font-mono text-lg input-calculado"
                           onfocus="this.select()" oninput="calcularIvaYTotal()" required />
                    <span asp-validation-for="RegistroCompra.BaseImponible" class="text-red-500 text-xs"></span>
                </div>

                @* MONTO IVA *@
                <div>
                    <label asp-for="RegistroCompra.MontoIva" class="block text-xs font-bold text-green-700 uppercase">Monto IVA (Calculado)</label>
                    <input asp-for="RegistroCompra.MontoIva" id="txtIva" type="number" step="0.01"
                           class="mt-1 block w-full rounded border-green-300 bg-white p-2 text-right font-mono font-bold text-green-800"
                           onfocus="this.select()" oninput="calcularTotal()" required />
                    <span asp-validation-for="RegistroCompra.MontoIva" class="text-red-500 text-xs"></span>
                </div>
            </div>

            <div class="grid grid-cols-1 md:grid-cols-3 gap-4">
                <div>
                    <label asp-for="RegistroCompra.BaseImpGrav" class="block text-xs font-bold text-gray-600 uppercase">Base 0%</label>
                    <input asp-for="RegistroCompra.BaseImpGrav" id="txtBase0" type="number" step="0.01"
                           class="mt-1 block w-full rounded border-gray-300 p-2 text-right font-mono"
                           onfocus="this.select()" oninput="calcularTotal()" />
                </div>
                <div>
                    <label asp-for="RegistroCompra.BaseNoGraIva" class="block text-xs font-bold text-gray-600 uppercase">No Objeto</label>
                    <input asp-for="RegistroCompra.BaseNoGraIva" id="txtBaseNoObj" type="number" step="0.01"
                           class="mt-1 block w-full rounded border-gray-300 p-2 text-right font-mono"
                           onfocus="this.select()" oninput="calcularTotal()" />
                </div>
                <div>
                    <label asp-for="RegistroCompra.MontoIce" class="block text-xs font-bold text-gray-600 uppercase">Monto ICE</label>
                    <input asp-for="RegistroCompra.MontoIce" id="txtIce" type="number" step="0.01"
                           class="mt-1 block w-full rounded border-gray-300 p-2 text-right font-mono"
                           onfocus="this.select()" oninput="calcularTotal()" />
                </div>
            </div>

            <div class="pt-4 border-t border-gray-300">
                <label asp-for="RegistroCompra.MontoTotal" class="block text-sm font-bold text-gray-900 uppercase">TOTAL FACTURA</label>
                <input asp-for="RegistroCompra.MontoTotal" id="txtTotal" type="number" step="0.01"
                       class="mt-1 block w-full rounded border-gray-300 p-3 text-right font-mono input-total"
                       readonly required />
                <span asp-validation-for="RegistroCompra.MontoTotal" class="text-red-500 text-xs"></span>
            </div>
        </div>

        @* 4. BOTÓN FINAL *@
        <div class="flex justify-end pt-6 border-t border-gray-200">
            <a asp-page="Index" class="mr-4 px-6 py-2 text-sm font-medium text-gray-700 bg-white border border-gray-300 rounded-md hover:bg-gray-50 transition">
                Cancelar
            </a>
            <button type="submit" class="px-8 py-3 bg-indigo-600 hover:bg-indigo-700 text-white font-bold rounded shadow-lg transform transition hover:-translate-y-0.5">
                <i class="fas fa-save mr-2"></i> GUARDAR COMPRA
            </button>
        </div>

    </form>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }

    <script>
        // TASA DE IVA ACTUAL (15%)
        const TASA_IVA = 0.15;

        // Función para obtener valor numérico seguro
        function getVal(id) {
            const val = document.getElementById(id).value;
            return val === "" ? 0 : parseFloat(val);
        }

        function validarLongitudClave() {
            const input = document.getElementById('txtAutorizacionInput').value.trim();
            const valSpan = document.getElementById('valAutorizacionInput');

            if (input.length > 0 && (input.length !== 10 && input.length !== 49)) {
                valSpan.textContent = 'La clave debe tener 10 o 49 dígitos.';
                return false;
            }
            valSpan.textContent = '';
            return true;
        }

        function calcularIvaYTotal() {
            const baseGrav = getVal('txtBaseGrav');

            // Calcular IVA (Redondeo a 2 decimales)
            const ivaCalculado = (Math.round((baseGrav * TASA_IVA) * 100) / 100).toFixed(2);

            document.getElementById('txtIva').value = ivaCalculado;
            calcularTotal();
        }

        function calcularTotal() {
            const baseGrav = getVal('txtBaseGrav');
            const base0 = getVal('txtBase0');
            const baseNoObj = getVal('txtBaseNoObj');
            const iva = getVal('txtIva');
            const ice = getVal('txtIce');

            const total = baseGrav + base0 + baseNoObj + iva + ice;

            document.getElementById('txtTotal').value = total.toFixed(2);
        }

        function confirmarGuardado() {
            calcularTotal(); // Asegurar último cálculo
            const total = document.getElementById('txtTotal').value;
            const proveedor = document.getElementById('RegistroCompra_RazonSocialProveedor').value;

            return confirm(`¿Confirmar guardado?\n\nProveedor: ${proveedor}\nTotal: $${total}`);
        }

        // Mostrar/ocultar sección de documento modificado según tipo de comprobante
        function toggleDocModificado() {
            const tipoComprobante = document.getElementById('RegistroCompra_TipoComprobante').value;
            const seccion = document.getElementById('seccionDocModificado');
            if (tipoComprobante === '04' || tipoComprobante === '05') {
                seccion.style.display = 'block';
            } else {
                seccion.style.display = 'none';
            }
        }

        // Inicializar al cargar la página
        document.addEventListener('DOMContentLoaded', () => {
            calcularTotal();
            toggleDocModificado();
            
            // Agregar listener para cambio de tipo de comprobante
            const tipoSelect = document.getElementById('RegistroCompra_TipoComprobante');
            if (tipoSelect) {
                tipoSelect.addEventListener('change', toggleDocModificado);
            }
        });
    </script>
}