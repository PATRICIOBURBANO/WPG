@page
@model AtsManager.Pages.DashboardModel
@{ 
    ViewData["Title"] = "Dashboard";
}

<script src="https://cdn.tailwindcss.com"></script>
<link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">

<div class="py-6">
    <div class="mb-6">
        <h1 class="text-2xl font-bold text-gray-900">ATS Manager</h1>
        <p class="text-gray-500 text-sm">Accesos rápidos</p>
    </div>

    <!-- FILA 1: EMITIDOS / VENTAS -->
    <div class="mb-6">
        <h2 class="text-sm font-bold text-gray-500 mb-3 flex items-center uppercase tracking-wide">
            <i class="fas fa-arrow-up text-green-500 mr-2"></i>Emitidos
        </h2>
        <div class="grid grid-cols-2 md:grid-cols-4 gap-4">
            <a asp-page="/Ventas/Index" asp-route-tipo="01" class="bg-white rounded-xl shadow-sm border border-gray-200 p-5 hover:shadow-md hover:border-green-400 transition-all text-center group">
                <i class="fas fa-file-invoice text-3xl text-green-500 mb-3 group-hover:scale-110 transition-transform"></i>
                <p class="text-sm font-semibold text-gray-700">Facturas</p>
            </a>
            <a asp-page="/Ventas/Index" asp-route-tipo="04" class="bg-white rounded-xl shadow-sm border border-gray-200 p-5 hover:shadow-md hover:border-pink-400 transition-all text-center group">
                <i class="fas fa-file-alt text-3xl text-pink-500 mb-3 group-hover:scale-110 transition-transform"></i>
                <p class="text-sm font-semibold text-gray-700">NC Ventas</p>
            </a>
            <a asp-page="/Ventas/Index" asp-route-tipo="05" class="bg-white rounded-xl shadow-sm border border-gray-200 p-5 hover:shadow-md hover:border-blue-400 transition-all text-center group">
                <i class="fas fa-file-alt text-3xl text-blue-500 mb-3 group-hover:scale-110 transition-transform"></i>
                <p class="text-sm font-semibold text-gray-700">ND Ventas</p>
            </a>
            <a asp-page="/Retenciones/Index" class="bg-white rounded-xl shadow-sm border border-gray-200 p-5 hover:shadow-md hover:border-purple-400 transition-all text-center group">
                <i class="fas fa-percentage text-3xl text-purple-500 mb-3 group-hover:scale-110 transition-transform"></i>
                <p class="text-sm font-semibold text-gray-700">Ret. Ventas</p>
            </a>
        </div>
    </div>

    <!-- FILA 2: RECIBIDOS / COMPRAS -->
    <div class="mb-6">
        <h2 class="text-sm font-bold text-gray-500 mb-3 flex items-center uppercase tracking-wide">
            <i class="fas fa-arrow-down text-blue-500 mr-2"></i>Recibidos
        </h2>
        <div class="grid grid-cols-2 md:grid-cols-4 gap-4">
            <a asp-page="/Compras/Index" asp-route-tipo="01" class="bg-white rounded-xl shadow-sm border border-gray-200 p-5 hover:shadow-md hover:border-green-400 transition-all text-center group">
                <i class="fas fa-shopping-cart text-3xl text-green-500 mb-3 group-hover:scale-110 transition-transform"></i>
                <p class="text-sm font-semibold text-gray-700">Compras</p>
            </a>
            <a asp-page="/NCCompras/Index" class="bg-white rounded-xl shadow-sm border border-gray-200 p-5 hover:shadow-md hover:border-pink-400 transition-all text-center group">
                <i class="fas fa-file-alt text-3xl text-pink-500 mb-3 group-hover:scale-110 transition-transform"></i>
                <p class="text-sm font-semibold text-gray-700">NC Compras</p>
            </a>
            <a asp-page="/Compras/Index" asp-route-tipo="05" class="bg-white rounded-xl shadow-sm border border-gray-200 p-5 hover:shadow-md hover:border-blue-400 transition-all text-center group">
                <i class="fas fa-file-alt text-3xl text-blue-500 mb-3 group-hover:scale-110 transition-transform"></i>
                <p class="text-sm font-semibold text-gray-700">ND Compras</p>
            </a>
            <a asp-page="/RetencionesCompras/Index" class="bg-white rounded-xl shadow-sm border border-gray-200 p-5 hover:shadow-md hover:border-purple-400 transition-all text-center group">
                <i class="fas fa-percentage text-3xl text-purple-500 mb-3 group-hover:scale-110 transition-transform"></i>
                <p class="text-sm font-semibold text-gray-700">Ret. Compras</p>
            </a>
        </div>
    </div>

    <!-- FILA 3: OTROS -->
    <div class="mb-6">
        <h2 class="text-sm font-bold text-gray-500 mb-3 flex items-center uppercase tracking-wide">
            <i class="fas fa-cog text-amber-500 mr-2"></i>Otros
        </h2>
        <div class="grid grid-cols-2 md:grid-cols-5 gap-4">
            <a asp-page="/Descargas/Index" class="bg-white rounded-xl shadow-sm border border-gray-200 p-5 hover:shadow-md hover:border-indigo-400 transition-all text-center group">
                <i class="fas fa-download text-3xl text-indigo-500 mb-3 group-hover:scale-110 transition-transform"></i>
                <p class="text-sm font-semibold text-gray-700">Descargar SRI</p>
            </a>
            <a asp-page="/Descargas/Index" asp-page-handler="ImportarManual" class="bg-white rounded-xl shadow-sm border border-gray-200 p-5 hover:shadow-md hover:border-green-400 transition-all text-center group">
                <i class="fas fa-file-import text-3xl text-green-500 mb-3 group-hover:scale-110 transition-transform"></i>
                <p class="text-sm font-semibold text-gray-700">Importar XML</p>
            </a>
            <a asp-page="/Cargas/Index" class="bg-white rounded-xl shadow-sm border border-gray-200 p-5 hover:shadow-md hover:border-amber-400 transition-all text-center group">
                <i class="fas fa-file-alt text-3xl text-amber-500 mb-3 group-hover:scale-110 transition-transform"></i>
                <p class="text-sm font-semibold text-gray-700">Carga SRI TXT</p>
            </a>
            <a asp-page="/Reportes/Exportar" class="bg-white rounded-xl shadow-sm border border-gray-200 p-5 hover:shadow-md hover:border-blue-400 transition-all text-center group">
                <i class="fas fa-file-export text-3xl text-blue-500 mb-3 group-hover:scale-110 transition-transform"></i>
                <p class="text-sm font-semibold text-gray-700">Exportar ATS</p>
            </a>
            <a asp-page="/Empresas/Index" class="bg-white rounded-xl shadow-sm border border-gray-200 p-5 hover:shadow-md hover:border-gray-400 transition-all text-center group">
                <i class="fas fa-building text-3xl text-gray-500 mb-3 group-hover:scale-110 transition-transform"></i>
                <p class="text-sm font-semibold text-gray-700">Empresas</p>
            </a>
        </div>
    </div>

    <!-- FILA 4: REPORTES (adicional) -->
    <div class="mb-6">
        <h2 class="text-sm font-bold text-gray-500 mb-3 flex items-center uppercase tracking-wide">
            <i class="fas fa-chart-bar text-gray-500 mr-2"></i>Reportes
        </h2>
        <div class="grid grid-cols-2 md:grid-cols-4 gap-4">
            <a asp-page="/Reportes/Ventas" class="bg-white rounded-xl shadow-sm border border-gray-200 p-5 hover:shadow-md hover:border-gray-400 transition-all text-center group">
                <i class="fas fa-chart-line text-3xl text-gray-500 mb-3 group-hover:scale-110 transition-transform"></i>
                <p class="text-sm font-semibold text-gray-700">Reportes</p>
            </a>
            <a asp-page="/Reportes/TalonResumen" class="bg-white rounded-xl shadow-sm border border-gray-200 p-5 hover:shadow-md hover:border-gray-400 transition-all text-center group">
                <i class="fas fa-clipboard-list text-3xl text-gray-500 mb-3 group-hover:scale-110 transition-transform"></i>
                <p class="text-sm font-semibold text-gray-700">Talón Resumen</p>
            </a>
        </div>
    </div>
</div>
@section Scripts {
}
